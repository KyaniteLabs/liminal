else if (cmd === 'quality') {
  const subCmd = cmdArgs[0];
  if (!subCmd || (subCmd !== 'run' && subCmd !== 'gate')) {
    console.error('Usage: sinter quality <run|gate>');
    console.error('  run   --spec <path>   Run a golden suite');
    console.error('  gate  --spec <path>   Block promotion on regression');
    process.exit(1);
  }

  const { EvaluationFabric } = await import('../dist/evaluation/EvaluationFabric.js');
  const { GoldenSuiteRunner } = await import('../dist/release/GoldenSuiteRunner.js');
  const { PromotionGate } = await import('../dist/release/PromotionGate.js');

  const suitePath = flags.spec;
  if (!suitePath) {
    console.error('Error: --spec <path> is required (path to golden suite JSON)');
    process.exit(1);
  }

  const suiteJson = fs.readFileSync(suitePath, 'utf-8');
  const suite = JSON.parse(suiteJson);

  console.log('');
  console.log('◆ Sinter Quality Gate');
  console.log(`  Suite: ${suite.name} (${suite.cases.length} cases)`);
  console.log('');

  const runner = new GoldenSuiteRunner({
    qualityThreshold: flags.confidenceThreshold,
    onCaseComplete: (id, passed, score) => {
      const icon = passed ? 'PASS' : 'FAIL';
      console.log(`  ${icon} ${id}: ${score.toFixed(3)}`);
    },
  });

  const result = await runner.run(suite);
  console.log('');
  console.log(`  Result: ${result.aggregate.passed}/${result.aggregate.total} passed`);
  console.log(`  Average score: ${result.aggregate.averageScore.toFixed(3)}`);
  console.log(`  Duration: ${result.durationMs}ms`);

  if (subCmd === 'gate') {
    console.log('');
    const gate = new PromotionGate({ maxRegressions: 0 });
    const gateResult = gate.check(result.aggregate);
    console.log(gateResult.summary);
    console.log('');
    process.exit(gateResult.passed ? 0 : 1);
  } else {
    console.log(`  Suite passed: ${result.aggregate.suitePassed}`);
    console.log('');
    process.exit(result.aggregate.suitePassed ? 0 : 1);
  }
}
else if (cmd === 'fix') {
  // Fix command - auto-fix code issues with LLM assistance
  const fixTarget = cmdArgs[0];

  console.log('');
  console.log('🔧 Sinter Fix');
  console.log('');

  // Validate and normalize confirm option
  const confirmLevel = flags.confirm || 'ask';
  if (!['auto', 'ask', 'never'].includes(confirmLevel)) {
    console.error('Error: --confirm must be one of: auto, ask, never');
    process.exit(1);
  }

  // Build fix configuration from parsed arguments
  const fixConfig = {
    target: fixTarget,
    error: flags.error,
    testFailures: flags.testFailures,
    testFile: flags.testFile,
    dryRun: flags.dryRun,
    confirm: confirmLevel,
  };

  // Determine fix type based on arguments
  let fixType = 'natural-language';
  if (flags.testFailures) {
    fixType = 'test-failures';
  } else if (flags.testFile || flags.error || (fixTarget && fixTarget.match(/\.(ts|js|tsx|jsx)$/))) {
    fixType = 'file-error';
  }

  // Import and use AutoFixOrchestrator
  const { AutoFixOrchestrator } = await import('../dist/fix/index.js');
  const llmClient = new LLMClient({ role: 'generator' });
  const orchestrator = new AutoFixOrchestrator(llmClient);

  // Build and execute the fix request
  const fixRequest = {
    type: fixType,
    target: fixTarget || flags.testFile,
    errorDescription: flags.error || fixTarget, // For natural language, use target as description
    dryRun: flags.dryRun,
    confirmLevel: confirmLevel,
  };

  console.log('Starting fix...');
  console.log('  Type:', fixType);
  console.log('  Target:', fixRequest.target || '(none)');
  console.log('');

  try {
    const result = await orchestrator.executeFix(fixRequest);

    console.log('');
    if (result.success) {
      console.log('✅ Fix completed successfully!');
    } else {
      console.log('❌ Fix failed');
      if (result.error) {
        console.log('   Error:', result.error);
      }
    }
    console.log('   Task ID:', result.taskId);
    console.log('   Changes:', result.changes.length);
    console.log('   Build passed:', result.buildPassed);
    console.log('   Tests passed:', result.testsPassed);
    if (result.rolledBack) {
      console.log('   ⚠️  Changes were rolled back');
    }
    console.log('');

    process.exit(result.success ? 0 : 1);
  } catch (error) {
    console.error('❌ Fix execution error:', error.message);
    process.exit(1);
  }
}
else if (cmd === 'fs') {
  const subCmd = cmdArgs[0];
  const { SinterFS } = await import('../dist/fs/index.js');
  const sinterFs = SinterFS.open(process.cwd());

  try {
    if (subCmd === 'artifacts') {
      // List all refs (which point to artifacts) from .sinter/refs/
      const fs = await import('fs');
      const refsDir = path.join(process.cwd(), '.sinter', 'refs');
      if (!fs.existsSync(refsDir)) {
        console.log('No artifacts found.');
        process.exit(0);
      }
      const entries = fs.readdirSync(refsDir).filter(f => f.endsWith('.json'));
      if (entries.length === 0) {
        console.log('No artifacts found.');
        process.exit(0);
      }
      console.log(`\n📦 Artifacts (${entries.length}):\n`);
      for (const entry of entries) {
        const ref = JSON.parse(fs.readFileSync(path.join(refsDir, entry), 'utf-8'));
        const shortHash = ref.hash ? ref.hash.slice(0, 12) : '????';
        console.log(`  ${entry.replace('.json', '')}  ${ref.kind}  ${shortHash}…`);
      }
      console.log('');
    } else if (subCmd === 'refs') {
      const refName = cmdArgs[1];
      if (!refName) {
        // List all refs
        const fs = await import('fs');
        const refsDir = path.join(process.cwd(), '.sinter', 'refs');
        if (!fs.existsSync(refsDir)) {
          console.log('No refs found.');
          process.exit(0);
        }
        const entries = fs.readdirSync(refsDir).filter(f => f.endsWith('.json'));
        console.log(`\n🔖 Refs (${entries.length}):\n`);
        for (const entry of entries) {
          console.log(`  ${entry.replace('.json', '')}`);
        }
        console.log('');
      } else {
        const ref = sinterFs.readRef(refName);
        if (!ref) {
          console.error(`Ref not found: ${refName}`);
          process.exit(1);
        }
        console.log(JSON.stringify(ref, null, 2));
      }
    } else if (subCmd === 'runs') {
      // Query EventStore for run_record events
      const projectStore = sinterFs.getProjectStore();
      const eventStore = projectStore.getEventStore();
      // EventStore has queryEvents method — use it to filter run_record events
      const events = eventStore.queryEvents({ type: 'run_record' });
      if (!events || events.length === 0) {
        console.log('No runs recorded.');
        process.exit(0);
      }
      console.log(`\n🏃 Runs (${events.length}):\n`);
      for (const event of events) {
        const data = event.payload || event.data || event;
        const runId = data.runId || 'unknown';
        const status = data.status || 'unknown';
        const project = data.project || '';
        console.log(`  ${String(runId).slice(0, 12)}…  ${String(status).padEnd(10)}  ${project}`);
      }
      console.log('');
    } else {
      console.log('Usage: sinter fs <artifacts|refs|runs>');
      console.log('  sinter fs artifacts          List all tracked artifacts');
      console.log('  sinter fs refs [name]        List refs or show specific ref');
      console.log('  sinter fs runs               List recorded runs');
      process.exit(1);
    }
  } finally {
    sinterFs.close();
  }
}
else if (cmd === 'ledger') {
  const { SinterFS } = await import('../dist/fs/index.js');
  const { TaskLedger } = await import('../dist/ledger/index.js');
  const { parseArgs, execute } = await import('../dist/ledger/cli.js');

  const sinterFs = SinterFS.open(process.cwd());
