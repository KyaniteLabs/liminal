else if (cmd === 'report' && cmdArgs[0] === 'garden') {
  const { GardenHealthMonitor } = await import('../dist/autonomy/GardenHealthMonitor.js');
  const { StagnationDetector } = await import('../dist/autonomy/StagnationDetector.js');
  const { NicheQuotaPolicy } = await import('../dist/autonomy/NicheQuotaPolicy.js');
  const { SinterFS } = await import('../dist/fs/index.js');
  const { EmergenceHooks } = await import('../dist/emergence/index.js');

  const sinterFs = SinterFS.open(process.cwd());
  try {
    const hooks = new EmergenceHooks(sinterFs);
    const archive = hooks.getArchive();
    const cells = archive.getAllCells();
    const healthMonitor = new GardenHealthMonitor();
    const nichePolicy = new NicheQuotaPolicy();
    const stagnation = new StagnationDetector();

    console.log('');
    console.log('=== Garden Report ===');

    const health = healthMonitor.measure(cells);
    console.log(`  Health: ${(health.healthScore * 100).toFixed(1)}% [${health.healthLevel}]`);
    console.log(`  Archive: ${health.archiveSize} entries  Occupancy: ${(health.nicheOccupancy * 100).toFixed(1)}%`);
    console.log(`  Avg lineage depth: ${health.avgLineageDepth.toFixed(1)}  Fertility yield: ${health.fertilityYield.toFixed(3)}`);
    console.log(`  Taste alignment: ${(health.tasteAlignment * 100).toFixed(1)}%`);

    const balance = nichePolicy.getBalanceScore(cells);
    console.log(`  Niche balance: ${(balance * 100).toFixed(1)}%`);

    // Gallery summary
    const { GalleryBuilder } = await import('../dist/product/index.js');
    const galleryBuilder = new GalleryBuilder();
    const gallery = galleryBuilder.build(cells);
    console.log(`  Gallery: ${gallery.totalItems} items in ${gallery.groups.length} groups`);

    const stagResult = stagnation.detect(healthMonitor.getHistory());
    if (stagResult.isStagnant) {
      console.log('');
      console.log(`  WARNING: Stagnation detected (severity: ${(stagResult.severity * 100).toFixed(0)}%)`);
      for (const r of stagResult.recommendations) {
        console.log(`    → ${r}`);
      }
    }

    console.log('');
  } finally {
    sinterFs.close();
  }
  process.exit(0);
}
else if (cmd === 'report' && cmdArgs[0] === 'readiness') {
  const { LaunchSummaryBuilder } = await import('../dist/reporting/index.js');
  const { GardenHealthMonitor } = await import('../dist/autonomy/GardenHealthMonitor.js');
  const { PolicyChangeManifest } = await import('../dist/release/PolicyChangeManifest.js');
  const { CreativeWeaknessEmitter } = await import('../dist/autonomy/CreativeWeaknessEmitter.js');
  const { SinterFS } = await import('../dist/fs/index.js');
  const { EmergenceHooks } = await import('../dist/emergence/index.js');

  const sinterFs = SinterFS.open(process.cwd());
  try {
    const hooks = new EmergenceHooks(sinterFs);
    const archive = hooks.getArchive();
    const cells = archive.getAllCells();
    const healthMonitor = new GardenHealthMonitor();
    const health = healthMonitor.measure(cells);
    const manifest = new PolicyChangeManifest();
    const changes = manifest.getByStatus('promoted');
    const emitter = new CreativeWeaknessEmitter();
    const weaknesses = emitter.getRecent ? [] : [];

    const builder = new LaunchSummaryBuilder();
    const readiness = builder.assess(health, changes, weaknesses);

    console.log('');
    console.log('=== Launch Readiness Report ===');
    console.log(`  Ready: ${readiness.ready ? 'YES' : 'NO'}`);
    console.log(`  Score: ${(readiness.score * 100).toFixed(0)}%`);
    console.log('');
    console.log('  Checks:');
    for (const check of readiness.checks) {
      const icon = check.passed ? 'PASS' : 'FAIL';
      console.log(`    ${icon} ${check.name}: ${check.detail}`);
    }
    if (readiness.blockers.length > 0) {
      console.log('');
      console.log('  Blockers:');
      for (const b of readiness.blockers) console.log(`    - ${b}`);
    }
    console.log('');
  } finally {
    sinterFs.close();
  }
  process.exit(0);
}
else if (cmd === 'garden' && cmdArgs[0] === 'start') {
  const mode = flags.mode || 'co-create';
  if (!['assist', 'co-create', 'autopilot'].includes(mode)) {
    console.error(`Error: Invalid mode "${mode}". Use assist, co-create, or autopilot.`);
    process.exit(1);
  }
  const { AutonomousGardener } = await import('../dist/autonomy/AutonomousGardener.js');
  const { SinterFS } = await import('../dist/fs/index.js');
  const { EmergenceHooks } = await import('../dist/emergence/index.js');

  const sinterFs = SinterFS.open(process.cwd());
  const hooks = new EmergenceHooks(sinterFs);
  const axes = ['order-chaos', 'sparse-dense', 'symmetry-asymmetry', 'smooth-bursty', 'static-evolving', 'harmonic-dissonant'];

  const gardener = new AutonomousGardener({ mode, totalBudget: 100 });
  // Hydrate the latest taste model so interactive replay bias actually steers
  // the loop — same block `garden tend` uses. Without it isModelLoaded() is false
  // and replay silently falls back to fertility ranking (the bug B16).
  try {
    const { TasteLearningService } = await import('../dist/learning/TasteLearningService.js');
    const weights = new TasteLearningService(sinterFs).loadLatestModel();
    if (weights) { gardener.loadTasteModel(weights); console.log('  taste model: loaded — replay bias ACTIVE'); }
    else { console.log('  taste model: none persisted yet — replay bias inactive'); }
  } catch (err) {
    console.log(`  taste model: hydration unavailable (${err?.message ?? err})`);
  }
  console.log('');
  console.log(`=== Garden Started (mode: ${mode}) ===`);
  console.log(`  Budget: 100 units  Press Ctrl+C to stop`);
  console.log('');

  let cycleCount = 0;
  gardener.start(
    () => { const a = hooks.getArchive(); return a.getAllCells(); },
    () => axes,
    (result) => {
      cycleCount++;
      const breakdown = result.taskBreakdown;
      const parts = [`actions=${result.actions}`, `health=${(result.health.healthScore * 100).toFixed(0)}%`, `budget=${result.budgetRemaining}`];
      if (breakdown) parts.push(`fresh=${breakdown.fresh} replay=${breakdown.replay} dream=${breakdown.dream}`);
      if (result.dreamResults?.length) parts.push(`dreamDescs=${result.dreamResults.length}`);
      if (result.tasteAlignedCount) parts.push(`tasteAligned=${result.tasteAlignedCount}`);
      console.log(`  [Cycle ${result.cycle}] ${parts.join(' ')}`);
      if (result.stagnation.isStagnant) {
        console.log(`    ⚠ Stagnation: ${(result.stagnation.severity * 100).toFixed(0)}%`);
      }
    },
  );

  process.on('SIGINT', () => {
    gardener.stop();
    sinterFs.close();
    console.log('');
    console.log(`  Garden stopped after ${cycleCount} cycles.`);
    process.exit(0);
  });
}
else if (cmd === 'garden' && cmdArgs[0] === 'stop') {
  console.log('No garden running in this process. Use Ctrl+C on the running garden start process.');
  process.exit(0);
}
else if (cmd === 'garden' && cmdArgs[0] === 'tend') {
  // Bounded, non-interactive gardener pass for daemons/cron: runs cycles until
  // the budget is exhausted, then persists the dream plan so the next
  // self-improve cycle can generate from it (gardener → dreams → generations).
  const budget = Math.max(10, parseInt(cmdArgs[1] || '100', 10) || 100);
  const { AutonomousGardener } = await import('../dist/autonomy/AutonomousGardener.js');
  const { DreamPlanner } = await import('../dist/dreaming/DreamPlanner.js');
  const { DreamQueue } = await import('../dist/dreaming/DreamQueue.js');
  const { SinterFS } = await import('../dist/fs/index.js');
  const { EmergenceHooks } = await import('../dist/emergence/index.js');

  const sinterFs = SinterFS.open(process.cwd());
  try {
    const hooks = new EmergenceHooks(sinterFs);
    const axes = ['order-chaos', 'sparse-dense', 'symmetry-asymmetry', 'smooth-bursty', 'static-evolving', 'harmonic-dissonant'];
    const cells = hooks.getArchive().getAllCells();
    const gardener = new AutonomousGardener({ mode: 'co-create', totalBudget: budget });

    console.log('');
    console.log(`=== Garden Tend (bounded, budget ${budget}, ${cells.length} cells) ===`);
    // Hydrate the latest taste model so replay bias actually steers the
    // autonomous loop: it trains hourly, but without this load isModelLoaded()
    // is false in every daemon tend and the bias silently no-ops (the TUI
    // bridge was the only consumer).
    try {
      const { TasteLearningService } = await import('../dist/learning/TasteLearningService.js');
      const weights = new TasteLearningService(sinterFs).loadLatestModel();
      if (weights) { gardener.loadTasteModel(weights); console.log('  taste model: loaded — replay bias ACTIVE'); }
      else { console.log('  taste model: none persisted yet — replay bias inactive'); }
    } catch (err) {
      console.log(`  taste model: hydration unavailable (${err?.message ?? err})`);
    }
    let cycles = 0;
    let lastHealth = 0;
    let result;
    while ((result = gardener.cycle(cells, axes)) !== null) {
      cycles++;
      lastHealth = result.health.healthScore;
      const stag = result.stagnation.isStagnant ? `  stagnation=${(result.stagnation.severity * 100).toFixed(0)}%` : '';
      console.log(`  [cycle ${result.cycle}] actions=${result.actions} health=${(result.health.healthScore * 100).toFixed(1)}% budget=${result.budgetRemaining}${stag}`);
    }

    // Persist the dream plan from the same planner the gardener uses. The planner
    // is told which pairings are already in the queue (queued/completed/failed) so
    // it proposes FRESH recombinations from the unexplored pair space instead of
    // re-proposing completed pairs — which dedup to +0 and starve dreaming.
    const queuePath = path.join(process.env.HOME || '/tmp', '.sinter', 'dreams', 'queue.json');
    const dreams = new DreamQueue({ persistPath: queuePath });
    const seen = new Set(dreams.getTasks().map((t) => `${t.strategy}:${t.sources.map((s) => s.id).sort().join('+')}`));
    // Reclaim queue slots held by FINISHED dreams (completed/failed). Without this
    // the queue saturates at maxQueueSize (50) with history and enqueue is blocked
    // forever (dreams: +0), so the gardener can never feed new recombinations to
    // the loop. `seen` was captured first so this plan still avoids re-proposing
    // already-tried pairings.
    const pruned = dreams.prune();
    const plan = new DreamPlanner().plan(cells, axes, { excludeKeys: seen });
    let enqueued = 0;
    for (const t of plan.tasks) {
      if (dreams.enqueue(t.strategy, t.sources, t.priority)) { enqueued++; }
    }
    if (pruned > 0) console.log(`  pruned ${pruned} finished dream(s) to free queue slots`);
    const status = dreams.getStatus();
    console.log(`  done: cycles=${cycles} finalHealth=${(lastHealth * 100).toFixed(1)}%`);
    console.log(`  dreams: +${enqueued} new (queued=${status.queued} completed=${status.completed}) → ${queuePath}`);
  } finally {
    sinterFs.close();
  }
  process.exit(0);
}
else if (cmd === 'ship' && cmdArgs[0] === 'garden') {
  const candidateRef = flags.candidate;
  const { PolicyChangeManifest } = await import('../dist/release/PolicyChangeManifest.js');
  const { CreativeRuntimeCandidateBuilder } = await import('../dist/release/CreativeRuntimeCandidateBuilder.js');
  const { GardenPromotionGate } = await import('../dist/release/GardenPromotionGate.js');
  const { LaunchSummaryBuilder } = await import('../dist/reporting/index.js');
  const { GardenHealthMonitor } = await import('../dist/autonomy/GardenHealthMonitor.js');
  const { CreativeWeaknessEmitter } = await import('../dist/autonomy/CreativeWeaknessEmitter.js');

  // Readiness gate check
  const { SinterFS } = await import('../dist/fs/index.js');
  const { EmergenceHooks } = await import('../dist/emergence/index.js');
  const healthMonitor = new GardenHealthMonitor();
  const readinessBuilder = new LaunchSummaryBuilder();
  const sinterFs = SinterFS.open(process.cwd());
  const hooks = new EmergenceHooks(sinterFs);
  const archive = hooks.getArchive();
  const cells = archive.getAllCells();
  const health = healthMonitor.measure(cells);
  const preCheckManifest = new PolicyChangeManifest();
  const preChanges = preCheckManifest.getByStatus('promoted');
  const emitter = new CreativeWeaknessEmitter();
  const weaknesses = emitter.getRecent ? [] : [];
  const readiness = readinessBuilder.assess(health, preChanges, weaknesses);

  if (!readiness.ready && !flags.force) {
    console.log('');
    console.log('=== Launch Readiness Gate ===');
    console.log(`  NOT READY (score: ${(readiness.score * 100).toFixed(0)}%)`);
    console.log('  Blockers:');
    for (const b of readiness.blockers) console.log(`    - ${b}`);
    console.log('');
    console.log('  Use --force to proceed anyway.');
    console.log('');
    process.exit(1);
  } else if (!readiness.ready && flags.force) {
    console.log('');
    console.log(`  WARNING: Launch not ready (score: ${(readiness.score * 100).toFixed(0)}%), but --force was specified.`);
    console.log('');
  }

  const manifest = new PolicyChangeManifest();
  const builder = new CreativeRuntimeCandidateBuilder();
  const gate = new GardenPromotionGate();

  const changes = manifest.getByStatus('promoted');
  if (changes.length === 0) {
    console.log('No promoted changes to ship.');
    process.exit(0);
  }

  const candidate = builder.build(changes, candidateRef || 'garden-release');
  const result = gate.check(candidate);

  console.log('');
  console.log('=== Ship Garden ===');
  console.log(`  Candidate: ${candidate.id}`);
  console.log(`  Changes: ${changes.length}`);
  console.log(`  Validation: ${(candidate.validationScore * 100).toFixed(0)}%`);
  console.log(`  Gate: ${result.passed ? 'PASSED' : 'BLOCKED'}`);

  if (result.improvements.length > 0) {
    console.log('  Improvements:');
    for (const imp of result.improvements) console.log(`    + ${imp}`);
  }
  if (result.regressions.length > 0) {
    console.log('  Regressions:');
    for (const reg of result.regressions) console.log(`    - ${reg}`);
  }
  console.log('');
  process.exit(0);
}
else if (cmd === 'ship' && cmdArgs[0] === 'rollback') {
  const toRef = flags.to;
  if (!toRef) {
    console.error('Error: --to <releaseRef> is required');
    process.exit(1);
  }
  const { PolicyChangeManifest } = await import('../dist/release/PolicyChangeManifest.js');
  const { GardenRollbackController } = await import('../dist/release/GardenRollbackController.js');

  const manifest = new PolicyChangeManifest();
  const controller = new GardenRollbackController(manifest);

  const rollbackResult = controller.rollback(toRef, 'Manual rollback');
  console.log('');
  console.log(`  Rollback ${rollbackResult.rolledBack ? 'succeeded' : 'failed'}: ${rollbackResult.reason}`);
  console.log('');
  process.exit(0);
}
else if (cmd === 'demo' && cmdArgs[0] === 'creative-codex') {
  const { DemoScenarioRunner } = await import('../dist/product/DemoScenarioRunner.js');

  const runner = new DemoScenarioRunner();
  const result = runner.runCreativeCodex();

  console.log('');
  console.log('=== Creative Codex Demo ===');
  console.log(`  Scenario: ${result.scenarioName}`);
  console.log(`  Steps: ${result.totalSteps}  Passed: ${result.passed}  Duration: ${result.durationMs}ms`);
  console.log('');

  for (const step of result.steps) {
    console.log(`  ${step.step}. ${step.label}`);
    console.log(`     ${step.description}`);
    const keys = Object.keys(step.data);
    if (keys.length > 0) {
      const summary = keys.map(k => `${k}=${JSON.stringify(step.data[k])}`).join(', ');
      console.log(`     Data: ${summary}`);
    }
  }
  console.log('');
  process.exit(0);
}
else if (cmd === 'prompt' && cmdArgs[0] === 'synthesize') {
  const inputPath = flags.input;
  if (!inputPath) {
    console.error('Usage: sinter prompt synthesize --input <graph.json> [--output <output.md>]');
    process.exit(1);
  }

  const { synthesizePrompt } = await import('../dist/nodeprompt/index.js');

  try {
    const graphJson = fs.readFileSync(inputPath, 'utf-8');
    const graph = JSON.parse(graphJson);
    if (!graph.nodes || !graph.edges || !graph.originalPrompt) {
      console.error('Graph JSON must contain: { nodes, edges, originalPrompt }');
      process.exit(1);
    }

    const result = synthesizePrompt(graph.originalPrompt, graph.nodes, graph.edges);
    const outputPath = flags.output;
    if (outputPath) {
      fs.writeFileSync(outputPath, result);
      console.log(`Synthesized prompt written to: ${outputPath}`);
    } else {
      console.log(result);
    }
    process.exit(0);
  } catch (err) {
    console.error('Prompt synthesis failed:', err.message);
    process.exit(1);
  }
}
else {
  console.error('');
  if (cmd) {
    console.error(`Unknown command or subcommand: ${[cmd, ...cmdArgs].join(' ')}`);
    console.error('Run "sinter --help" to see available commands and subcommands.');
  } else {
    console.error('Run "sinter --help" for usage, or: sinter "your idea"');
  }
  process.exit(1);
}
