    const report = runLevel6ReleaseGate({
      repoRoot,
      candidate: flags.dryRun === true,
      includeMarketReadiness: flags.dryRun === true ? false : undefined,
    });
    console.log('');
    console.log('=== Level 6 release gate ===');
    console.log(`Level: ${report.level}`);
    console.log(`Ready: ${report.ready ? 'YES' : 'NO'}`);
    for (const check of report.checks) {
      console.log(`${check.status === 'pass' ? 'PASS' : 'FAIL'} ${check.label}: ${check.evidence}`);
    }
    if (report.blockers.length > 0) {
      console.log('');
      console.log('Blockers:');
      for (const blocker of report.blockers) console.log(`- ${blocker}`);
    }
    if (flags.output) {
      fs.writeFileSync(flags.output, `${JSON.stringify(report, null, 2)}\n`, 'utf-8');
      console.log('');
      console.log(`Wrote Level 6 release gate report: ${flags.output}`);
    }
    console.log('');
