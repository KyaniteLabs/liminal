// Load role definitions for LLMClient
await LLMClient.loadRoles();

const naturalLanguagePrompt = inferNaturalLanguagePrompt(cmd, cmdArgs);
if (naturalLanguagePrompt && flags.prompt === undefined) {
  // Command-shaped near-misses must not silently become PAID generations
  // (audit F8): a typo'd command or a quoted "command subcommand" phrase gets
  // a did-you-mean error with an explicit escape hatch instead.
  const typo = suggestCommandForTypo(cmd, cmdArgs);
  if (typo) {
    if (typo.reason === 'quoted-phrase') {
      console.error(`"${cmd}" looks like the "${typo.command}" command quoted as one argument.`);
      console.error(`Did you mean: sinter ${cmd}  (without quotes)?`);
    } else {
      console.error(`Unknown command "${cmd}" — did you mean "${typo.command}"?`);
    }
    console.error(`To generate art from this text instead, run: sinter --prompt ${JSON.stringify(naturalLanguagePrompt)}`);
    process.exit(1);
  }
  flags.prompt = naturalLanguagePrompt;
}

if (naturalLanguagePrompt && flags.prompt && isSelfImprovementPrompt(flags.prompt)) {
  const { LLMModeSelfImprovementRuntime } = await import('../dist/runtime-core/SelfImprovementRuntime.js');
  const outDir = flags.output || path.join('.omx', 'self-improvement', new Date().toISOString().replace(/[:.]/g, '-'));
  fs.mkdirSync(outDir, { recursive: true });

  const runtime = new LLMModeSelfImprovementRuntime();
  const llm = new LLMClient({ role: 'harness' });
  const prepared = runtime.prepare({ llm, description: flags.prompt });
  const taskJsonPath = path.join(outDir, 'self-improvement-task.json');
  const taskMdPath = path.join(outDir, 'self-improvement-task.md');
  fs.writeFileSync(taskJsonPath, `${JSON.stringify(prepared.task, null, 2)}\n`, 'utf-8');
  fs.writeFileSync(taskMdPath, [
    '# Sinter Self-Improvement Task Packet',
    '',
    `Task: ${prepared.task.title}`,
    `Task ID: ${prepared.taskId}`,
    `Model: ${prepared.modelName}`,
    `Domain: ${prepared.task.domain}`,
    `Focus file: ${prepared.task.fileHint}`,
    '',
    '## Working set',
    ...prepared.task.workingSet.map((file) => `- ${file}`),
    '',
    '## Verification targets',
    ...prepared.task.verificationTargets.map((target) => `- ${target.tool}${target.pattern ? ` (${target.pattern})` : ''}: ${target.reason}`),
    '',
    '## Description',
    '',
    prepared.task.description,
    '',
  ].join('\n'), 'utf-8');

  console.log('');
  console.log('🛠️ Sinter: Self-improvement request');
  console.log('✅ Routed to self-improvement task preparation, not creative generation.');
  console.log(`📁 Output: ${outDir}`);
  console.log(`✅ Task JSON: ${taskJsonPath}`);
  console.log(`✅ Task Markdown: ${taskMdPath}`);
  console.log(`🎯 Focus file: ${prepared.task.fileHint}`);
  console.log(`🧪 Verification: ${prepared.task.verificationTargets.map((target) => target.tool).join(', ')}`);

  const executeRequested = flags.confirm === 'auto' || flags.force === true;
  if (!executeRequested) {
    console.log('ℹ️  Add --confirm auto to execute this bounded self-improvement task in an isolated worktree.');
    console.log('');
    process.exit(0);
  }

  if (!isIsolatedWorktree() && process.env.LIMINAL_ALLOW_MAIN_WORKTREE_IMPROVE !== '1') {
    console.error('❌ Refusing to execute self-improvement in the main worktree.');
    console.error('   Create an isolated worktree, then rerun with --confirm auto.');
    process.exit(2);
  }

  prepared.task.requiresMutation = true;
  console.log('🚀 Executing bounded self-improvement task...');
  const result = await prepared.execute();
  const sessionSummary = summarizeSession(result);
  const sessionJsonPath = path.join(outDir, 'self-improvement-session.json');
  const sessionMdPath = path.join(outDir, 'self-improvement-session.md');
  fs.writeFileSync(sessionJsonPath, `${JSON.stringify(sessionSummary, null, 2)}\n`, 'utf-8');
  fs.writeFileSync(sessionMdPath, [
    '# Sinter Self-Improvement Session',
    '',
    `Status: ${sessionSummary.status}`,
    `Exit reason: ${sessionSummary.exitReason || 'n/a'}`,
    `Steps: ${sessionSummary.stepCount}`,
    `Mutated files: ${sessionSummary.mutatedFiles.length > 0 ? sessionSummary.mutatedFiles.join(', ') : 'none'}`,
    `Successful mutated files: ${sessionSummary.successfulMutatedFiles.length > 0 ? sessionSummary.successfulMutatedFiles.join(', ') : 'none'}`,
    '',
    `Session JSON: ${sessionJsonPath}`,
    '',
  ].join('\n'), 'utf-8');
  console.log(`✅ Session JSON: ${sessionJsonPath}`);
  console.log(`✅ Session Markdown: ${sessionMdPath}`);
  console.log(`📊 Status: ${sessionSummary.status}`);
  console.log(`📊 Steps: ${sessionSummary.stepCount}`);
  console.log(`✏️  Mutated files: ${sessionSummary.mutatedFiles.length > 0 ? sessionSummary.mutatedFiles.join(', ') : 'none'}`);
  console.log('');
  process.exit(sessionSummary.status === 'success' ? 0 : 1);
}

const hasOutputFlag = flags.output !== undefined;
const hasPromptFlag = flags.prompt !== undefined;
const isLiveMusic = flags.mode === 'live-music' || cmd === 'live-music';

if (hasOutputFlag && !hasPromptFlag && !cmd && !isLiveMusic) {
  console.error('Error: --prompt is required');
  process.exit(1);
}

// --- live-music mode: generateMusic + optional generateVisuals, write to --output, print paths ---
if (isLiveMusic) {
  const livePrompt = commandPrompt(flags.prompt, cmdArgs);
  // Guard empty AND whitespace-only prompts: a blank prompt silently fabricates
  // a generic template set (no real generation), so reject it loudly instead.
  if (!livePrompt || livePrompt.trim().length === 0) {
    console.error('Error: --prompt is required for live-music');
    process.exit(1);
  }
  const liveOutDir = flags.output || path.join(process.env.HOME || '/tmp', '.sinter', 'output');
  fs.mkdirSync(liveOutDir, { recursive: true });

  // Load project config for live settings (MIDI, OSC, syncMode) - pass through only
  let liveConfig = null;
  try {
    liveConfig = await loadProjectConfig(process.cwd());
  } catch (_) {}
  const liveOpts = liveConfig?.live || {};

  console.log('');
  console.log('🎵 Sinter: Live AV');
  console.log('📝 Prompt: "' + livePrompt + '"');
  console.log('📁 Output: ' + liveOutDir);
  if (liveOpts.oscHost || liveOpts.syncMode) {
    console.log('🔧 Live config: oscHost=' + (liveOpts.oscHost || '-') + ', syncMode=' + (liveOpts.syncMode || '-'));
  }
  console.log('');

  try {
    // generateMusic takes a single GenerateMusicOptions object — passing the
    // prompt as the first positional arg made `options.prompt` undefined, so the
    // strudel path ran on an empty prompt and fabricated a generic template.
    // Mirror the GUI call shape (gui/server.js): { prompt, platform: 'strudel' }.
    const musicResult = await generateMusic({ prompt: livePrompt, platform: 'strudel' });
    const strudelPath = path.join(liveOutDir, 'strudel.js');
    fs.writeFileSync(strudelPath, musicResult.code, 'utf-8');
    console.log('✅ Music: ' + strudelPath);

    const visualResult = await generateVisuals({ prompt: livePrompt, platform: 'hydra' });
    const hydraPath = path.join(liveOutDir, 'hydra.js');
    fs.writeFileSync(hydraPath, visualResult.code, 'utf-8');
    console.log('✅ Visuals: ' + hydraPath);
    console.log('');
  } catch (err) {
    console.error('❌ Error:', err.message);
    process.exit(1);
  }
  process.exit(0);
}

if (cmd === 'site') {
  const { runSiteEvolve } = await import('../dist/cli/SiteCommand.js');
  const subCmd = cmdArgs[0];

  if (subCmd !== 'evolve') {
    console.error('Usage: sinter site evolve [--once] [--dry-run] [--slot <id>]');
    process.exit(1);
  }

  // Parse from the full argv (`args`): the global flag loop consumes `--dry-run`
  // into `flags` and drops `--once`/`--slot`/`--interval`, so none reach `cmdArgs`.
  const options = {
    once: args.includes('--once'),
    dryRun: args.includes('--dry-run'),
    slot: (() => { const idx = args.indexOf('--slot'); return idx !== -1 ? args[idx + 1] : undefined; })(),
    interval: (() => { const idx = args.indexOf('--interval'); return idx !== -1 ? parseInt(args[idx + 1]) : undefined; })(),
  };

  await runSiteEvolve(options);
  process.exit(0);
}

if (cmd === 'generate' || cmd === 'gen' || cmd === 'g' || (flags.prompt && (!cmd || naturalLanguagePrompt))) {
  prompt = commandPrompt(flags.prompt, cmdArgs);
  if (!prompt) {
    console.error('Error: --prompt is required');
    process.exit(1);
  }
  if (flags.maxIterations) maxIterations = flags.maxIterations;
  if (flags.output) output = flags.output;

  const outDir = output || path.join(process.env.HOME || '/tmp', '.sinter', 'output');
  fs.mkdirSync(outDir, { recursive: true });

  console.log('');
  console.log('🎨 Sinter: Creative Coding Agent');
  console.log('📝 Prompt: "' + prompt + '"');
  console.log('🔄 Max iterations: ' + maxIterations);
  if (output) console.log('📁 Output: ' + output);
  console.log('');
  console.log('Generating:', prompt);
  console.log('');

  // Route generation + validation to the domain the prompt asks for (else the
  // loop defaults to p5 and a "GLSL shader" prompt fails p5 validation).
  const { detectPromptDomain } = await import('../dist/core/detectPromptDomain.js');
  const detectedDomain = await detectPromptDomain(prompt);
  if (detectedDomain) console.log('🎯 Detected domain: ' + detectedDomain + '\n');

  const aestheticConfig = {
    ...(loadAestheticConfig(flags.aestheticConfig) || {}),
    ...(flags.aesthetic ? { preset: flags.aesthetic } : {}),
  };

  run(prompt, {
    maxIterations: maxIterations,
    output: outDir,
    project: 'cli-project',
    collabDomain: detectedDomain,
    useSwarm: flags.useSwarm,
    swarmMode: flags.swarmMode,
    swarmConfig: flags.swarmRounds ? { maxRounds: flags.swarmRounds } : undefined,
    useAestheticGuardrails: !!(flags.aesthetic || flags.aestheticConfig),
    aestheticConfig: (flags.aesthetic || flags.aestheticConfig) ? aestheticConfig : undefined,
    useIntuition: !!flags.intuition,
    useArchiveLearning: !!flags.learn,
    archivePath: flags.learn ? path.join(process.env.HOME || '/tmp', '.sinter', 'archive', 'quality_archive.json') : undefined,
    voiceFile: flags.voiceFile,
    voice: flags.voice,
  }).then(async (result) => {
    console.log('');
    console.log('✅ Generation complete!');
    console.log('📊 Iterations: ' + result.iterations);
    console.log('⏱️ Time: ' + (result.duration / 1000).toFixed(1) + 's');
    console.log('🎯 Reason: ' + result.reason);
    // Mark a degraded score (evaluator-offline fallback) so it is never read as real
    // fitness by a human or the self-improve ledger that parses this line. The
    // machine-parseable suffix (failureClass=…, confidence=…) lets the ledger
    // record WHY a score is degraded, not just that it is.
    const degraded =
      (result.evaluationConfidence !== undefined && result.evaluationConfidence <= 0) ||
      result.evaluationFailureClass === 'scorer' ||
      result.evaluationFailureClass === 'infra';
    const degradedSuffix = degraded
      ? ` [degraded: evaluator unavailable, not real fitness] (failureClass=${result.evaluationFailureClass ?? 'unknown'}, confidence=${(result.evaluationConfidence ?? 0).toFixed(2)})`
      : '';
    console.log('⭐ Quality score: ' + result.finalScore.toFixed(2) + degradedSuffix);
    console.log('🤖 Model: ' + (result.model || 'unknown'));
    // Track in history
    await history.add(prompt);

    console.log('✅ Saved: ' + result.jsPath);
    if (result.htmlPath) console.log('✅ HTML: ' + result.htmlPath);
    if (result.zipPath) console.log('✅ Archive: ' + result.zipPath);
    try {
      const receiptLines = await writeCliCognitiveReceipt({ prompt, result });
      console.log('');
      for (const line of receiptLines) console.log(line);
    } catch (receiptErr) {
      const message = receiptErr instanceof Error ? receiptErr.message : String(receiptErr);
      console.log('');
      console.log('🧠 What Sinter learned: unavailable — ' + message);
    }
    console.log('');
    process.exit(0);
  }).catch(err => {
    console.error('');
    console.error('❌ Error:', err.message);
    console.error('');
    process.exit(1);
  });
}
else if (cmd === 'serve' || cmd === 's') {
  const port = cmdArgs[0] || 3456;
  // Wire the gallery dir so /api/gallery surfaces saved works (generations +
  // compositions). Defaults to cwd/gallery — the same dir generate/compose write to.
  const server = new PreviewServer(path.resolve(flags.gallery || 'gallery'));

  function findLatestSketch(dirs) {
    let latestSketch = null;
    let latestTime = 0;

    for (const dir of dirs) {
      if (!fs.existsSync(dir)) continue;

      const files = fs.readdirSync(dir, { recursive: true })
        .filter(f => f.endsWith('.js'))
        .map(f => ({ file: f, path: path.join(dir, f), stat: fs.statSync(path.join(dir, f)) }))
        .filter(({ stat }) => stat.isFile());

      for (const { file, path: fullPath, stat } of files) {
        if (stat.mtimeMs > latestTime) {
          latestTime = stat.mtimeMs;
          latestSketch = { file, path: fullPath };
        }
      }
    }
    return latestSketch;
  }

  const searchDirs = [
    path.join(process.env.HOME || '/tmp', '.sinter', 'output'),
    path.join(process.cwd(), 'gallery'),
  ];

  const latestSketch = findLatestSketch(searchDirs);
  let sketchCode = '';

  if (latestSketch) {
    sketchCode = fs.readFileSync(latestSketch.path, 'utf-8');
    console.log('📄 Loading sketch:', latestSketch.file);
  } else {
    console.log('⚠️  No sketches found. Generate one first:');
    console.log('   sinter --prompt "your idea"');
  }

  server.serveSketch(sketchCode);
  server.start(port).then(() => {
    console.log('✅ Server running on http://localhost:' + port);
  }).catch(err => {
    console.error('❌ Error starting server:', err.message);
    process.exit(1);
  });
}
else if (cmd === 'compost') {
  // Check for dual-model configuration
  let llm;
  let fastLLM;
  let modelRouter;

  // Check if dual-model flags are provided
  const hasDualModelFlags = flags.fastModel || flags.powerfulModel || flags.routingMode;

  if (hasDualModelFlags) {
    // Dual-model mode: create ModelRouter with two LLM clients
    const fastModelName = flags.fastModel || 'qwen3.5:9b';
    const powerfulModelName = flags.powerfulModel || 'qwen3:30b-a3b';
    const routingMode = flags.routingMode || 'cascade';
    const confidenceThreshold = flags.confidenceThreshold ?? 0.8;

    console.log(`[Compost] Dual-model mode:`);
    console.log(`  Fast model: ${fastModelName}`);
    console.log(`  Powerful model: ${powerfulModelName}`);
    console.log(`  Routing mode: ${routingMode}`);
    console.log(`  Confidence threshold: ${confidenceThreshold}`);
    console.log('');

    // Create primary (fast) LLM client
    const primaryLLM = new LLMClient({
      role: 'generator',
      provider: 'ollama',
      baseUrl: process.env.LIMINAL_LLM_BASE_URL || 'http://localhost:11434',
      model: fastModelName,
    });

    // Create secondary (powerful) LLM client
    const secondaryLLM = new LLMClient({
      role: 'generator',
      provider: 'ollama',
      baseUrl: process.env.LIMINAL_LLM_BASE_URL || 'http://localhost:11434',
      model: powerfulModelName,
    });

    // Create ModelRouter
    modelRouter = new ModelRouter(primaryLLM, secondaryLLM, {
      primary: {
        provider: 'ollama',
        model: fastModelName,
        temperature: 0.7,
        maxTokens: 2000,
      },
      secondary: {
        provider: 'ollama',
        model: powerfulModelName,
        temperature: 0.7,
        maxTokens: 2000,
      },
      routing: {
        mode: routingMode,
        confidenceThreshold,
        primaryConcurrency: 8,
        secondaryConcurrency: 4,
      },
    });

    // Use the router as the main LLM
    llm = modelRouter;
    fastLLM = primaryLLM; // For backward compatibility with fastLLM parameter
  } else {
    // Single-model mode (original behavior)
    llm = new LLMClient({ role: 'generator' });
    fastLLM = new LLMClient({ role: 'generator', provider: 'lmstudio' });
  }

  // Compost rehydrate subcommand — handled before parseArgs delegation
  if (cmdArgs[0] === 'rehydrate') {
    const { CompostRehydrator } = await import('../dist/compost/CompostRehydrator.js');
    const { CompostHeap } = await import('../dist/compost/CompostHeap.js');
    const { CompostShredder } = await import('../dist/compost/CompostShredder.js');

    const heap = new CompostHeap({ heapDir: path.join(process.cwd(), '.sinter', 'compost', 'heap') });
    const heapFiles = await heap.listFiles();
    if (heapFiles.length === 0) {
      console.log('No files in heap to rehydrate.');
      process.exit(0);
    }

    // Read heap files and shred into fragments
    const allFragments = [];
    for (const relPath of heapFiles) {
      const fullPath = path.join(process.cwd(), '.sinter', 'compost', 'heap', relPath);
      try {
        const content = fs.readFileSync(fullPath, 'utf-8');
        const frags = CompostShredder.shredSemantic(content, relPath, 'compost');
        allFragments.push(...frags);
      } catch (_) { /* skip unreadable files */ }
    }

    if (allFragments.length === 0) {
      console.log('No fragments extracted from heap files.');
      process.exit(0);
    }

    const rehydrator = new CompostRehydrator();
    const rehydratable = rehydrator.findRehydratable(allFragments);
    if (rehydratable.length === 0) {
      console.log('No fragments meet the motif density threshold for rehydration.');
      process.exit(0);
    }

    const candidates = rehydrator.rehydrate(rehydratable);
    console.log('');
    console.log(`Rehydrated ${candidates.length} candidates from ${rehydratable.length} fragments (${heapFiles.length} heap files):`);
    for (const c of candidates) {
      console.log(`  motifDensity=${c.motifDensity.toFixed(3)} complexity=${c.complexity.toFixed(3)} complete=${c.isComplete} sources=${c.sourceIds.length}`);
    }
    console.log('');
    process.exit(0);
  }

  const action = parseArgs(process.argv.slice(2));

  // Bootstrap metabolic entropy engine
  const { EventStore } = await import('../dist/compost/EventStore.js');
  const { MetabolicEntropyEngine } = await import('../dist/entropy/MetabolicEntropyEngine.js');
  const { initializeTelemetry, getTelemetry } = await import('../dist/guardrails/observation/TelemetryCollector.js');

  const eventStore = new EventStore({ projectRoot: process.cwd() });
  eventStore.init();

  let telemetry = getTelemetry();
  if (!telemetry) {
    telemetry = initializeTelemetry({ enabled: true, sampleRate: 1.0 });
  }

  const entropyEngine = new MetabolicEntropyEngine({
    eventStore,
    heap: { listFiles: async () => [] },
    telemetry,
  });

  const mill = new CompostMill(llm, { soupEnabled: true, fastLLM, modelRouter, entropy: entropyEngine });
  await execute(action, mill).catch(err => {
    console.error('Compost error:', err.message);
    process.exit(1);
  });
  process.exit(0);
}
else if (cmd === 'list' || cmd === 'ls') {
  const outDir = path.join(process.env.HOME || '/tmp', '.sinter', 'output');
  console.log('📁 Sketches:');
  if (fs.existsSync(outDir)) {
    fs.readdirSync(outDir).filter(f => f.endsWith('.js')).forEach(f => console.log('  ' + f));
  } else {
    console.log('  (none yet)');
  }
  process.exit(0);
}
else if (cmd === 'composite') {
  const specPath = flags.spec;
  if (!specPath) {
    console.error('Usage: sinter composite --spec <spec.json> [--output <plan.json>]');
    process.exit(1);
  }

  const { Compositor } = await import('../dist/composite/Compositor.js');
  const { CompositionAnalyzer } = await import('../dist/composition/CompositionAnalyzer.js');
  try {
    const specJson = fs.readFileSync(specPath, 'utf-8');
    const spec = JSON.parse(specJson);
    const compositor = new Compositor();
    compositor.validateSpec(spec);

    console.log('Composition Spec Analysis');
    console.log(`  Layers: ${spec.layers?.length ?? 0}`);

    const analyzer = new CompositionAnalyzer();

    // Map compositor layer types (video/image/audio) to composition domain hints
    const typeToDomain = { video: 'p5', image: 'svg', audio: 'tone' };

    for (const layer of spec.layers ?? []) {
      const domainHint = typeToDomain[layer.type] || layer.type;
      const recommendations = await analyzer.analyze(`Generate ${domainHint} visual`);
      console.log(`  [${layer.type} -> ${domainHint}] confidence=${recommendations[0]?.confidence ?? 'n/a'} reason=${recommendations[0]?.reason ?? 'n/a'}`);
    }

    // Note: PromptEnhancer requires full composition Layer objects (with .type, .enabled,
    // .metadata.prompt) which compositor stub layers don't provide. Skip enhancement here
    // — it's available via the composition pipeline when layers are created through generators.

    const outputPath = flags.output;
    if (outputPath) {
      const plan = { spec, analyzedAt: new Date().toISOString(), layers: spec.layers?.length ?? 0 };
      fs.writeFileSync(outputPath, JSON.stringify(plan, null, 2));
      console.log(`  Plan written to: ${outputPath}`);
    }
    console.log('Done.');
    process.exit(0);
  } catch (err) {
    console.error('Composite analysis failed:', err.message);
    process.exit(1);
  }
}
else if (cmd === 'compose') {
  // End-to-end layered work: generate every layer via the domain generators and
  // assemble one standalone composite HTML (stacked, blended visual layers +
  // audio). This is the "combine outputs" path — Sinter's core mixing capability.
  const specPath = flags.spec;
  const nlPrompt = flags.prompt || (cmdArgs.length ? cmdArgs.join(' ') : undefined);
  if (!specPath && !nlPrompt) {
    console.error('Usage: sinter compose (--prompt "<idea>" | --spec <spec.json>) [-o <dir>]');
    console.error('  --prompt: an LLM decomposes the idea into layers, then composes them');
    console.error('  --spec:   { "title", "background", "layers": [ { "domain", "prompt", "blendMode", "opacity" } ] }');
    console.error('  domains: p5, three, shader, hydra, ascii, html, tone, strudel');
    process.exit(1);
  }
  const outDir = flags.output || 'output';
  const { CompositionOrchestrator } = await import('../dist/composition/CompositionOrchestrator.js');
  const { harnessMemory } = await import('../dist/harness/HarnessMemory.js');
  try {
    let result;
    if (specPath) {
      const spec = JSON.parse(fs.readFileSync(specPath, 'utf-8'));
      console.log('🎨 Composing ' + (spec.layers?.length ?? 0) + ' layers...');
      console.log('');
      result = await CompositionOrchestrator.compose(spec);
    } else {
      console.log('🧩 Decomposing idea into layers...');
      console.log('');
      result = await CompositionOrchestrator.composeFromPrompt(nlPrompt);
    }
    fs.mkdirSync(outDir, { recursive: true });
    const htmlPath = path.join(outDir, 'composition.html');
    fs.writeFileSync(htmlPath, result.html, 'utf-8');
    for (const l of result.layers) {
      console.log('  [' + l.domain + '] ' + (l.generated
        ? 'ok — ' + l.codeLength + ' chars, blend=' + l.blendMode + ' opacity=' + l.opacity
        : 'FAILED: ' + l.error));
    }
    console.log('');
    console.log('✅ ' + result.successCount + '/' + result.layers.length + ' layers composed');
    console.log('✅ Saved: ' + htmlPath);
    // Surface the measured-frame grade (luminance + seam) the composite render gate computed.
    if (result.renderGate) {
      const g = result.renderGate;
      if (g.skipped) {
        console.log('🔎 Render gate: skipped (' + g.skipped + ')');
      } else if (g.measure) {
        console.log('🔎 Render gate: ' + String(g.verdict).toUpperCase()
          + ' — luminance ' + g.measure.meanLuminance.toFixed(3)
          + ', spread ' + (g.measure.brightnessStd ?? 0).toFixed(1));
        if (g.remediation) {
          console.log('   remediation: demoted layers [' + g.remediation.demotedLayers.join(',') + '] → '
            + g.remediation.verdictAfter + (g.remediation.applied ? ' (applied)' : ' (reverted)'));
        }
      }
    }
    const seamLayers = result.layers.filter(l => l.opaqueBackground).map(l => l.domain);
    if (seamLayers.length) {
      console.log('⚠️  Seam risk: foreground layer(s) paint an opaque background — ' + seamLayers.join(', '));
    }
    // Persist to the gallery so composed works are first-class citizens — browsable
    // and versioned alongside single-domain generations (e.g. via `sinter serve`).
    if (result.successCount > 0) {
      try {
        const { Gallery } = await import('../dist/gallery/Gallery.js');
        const galleryDir = path.resolve(flags.gallery || 'gallery');
        const gallery = new Gallery(galleryDir);
        const slug = (result.title || 'composition')
          .toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/^-+|-+$/g, '').slice(0, 40) || 'composition';
        const version = (await gallery.getLatestVersion(slug)) + 1;
        await gallery.saveComposition(slug, version, result.html, {
          title: result.title,
          layers: result.layers.filter(l => l.generated).map(l => l.domain),
        });
        console.log('🖼️  Gallery: ' + slug + ' v' + version);
      } catch (galErr) {
        console.log('⚠️  Gallery save skipped: ' + galErr.message);
      }
    }
    // Feed self-improvement: record this composition as a generation episode.
    try {
      await harnessMemory.initialize();
      harnessMemory.recordEpisode({
        type: 'generation',
        domain: 'composition',
        prompt: result.title + ' :: ' + result.layers.map(l => l.domain + ':' + l.prompt).join(' | '),
        code: result.html,
        score: result.layers.length ? result.successCount / result.layers.length : 0,
        tags: ['composition', ...result.layers.map(l => l.domain)],
      });
      await harnessMemory.save();
      console.log('🧠 Recorded composition episode for self-improvement');
    } catch (memErr) {
      console.log('⚠️  Episode not recorded: ' + memErr.message);
    }
    process.exit(result.successCount > 0 ? 0 : 1);
  } catch (err) {
    console.error('Compose failed:', err.message);
    process.exit(1);
  }
}
else if (cmd === 'chat' && cmdArgs[0] === 'reflect') {
  // Studio reflection: the studio model distills persisted chat sessions into a
  // taste signal and writes it to HarnessMemory, which GuidanceEngine reads forward
  // into future generations. The chat's human signal feeding the self-improvement
  // flywheel — runnable by any user (not only the background daemon).
  const { SinterFS } = await import('../dist/fs/index.js');
  const { LLMClient } = await import('../dist/llm/LLMClient.js');
  const { reflectUnreflectedSessions } = await import('../dist/learning/StudioReflection.js');
  const sinterFs = SinterFS.open(process.cwd());
  try {
    await LLMClient.loadRoles();
    const llm = new LLMClient({ role: 'studio' });
    const limit = Math.max(1, parseInt(cmdArgs[1] || '10', 10) || 10);
    console.log('');
    console.log('=== Chat Reflect (studio model distills persisted sessions → taste signal) ===');
    const res = await reflectUnreflectedSessions(sinterFs, llm, { limit });
    console.log(`  reflected ${res.reflected} session(s), skipped ${res.skipped}`);
    for (const s of res.signals) {
      console.log(`  [${s.sessionId.slice(0, 8)}] intent="${s.intentSummary.slice(0, 48)}" likes=${JSON.stringify(s.likes.slice(0, 3))} satisfaction=${s.satisfaction.toFixed(2)}`);
    }
    console.log('  → recorded to HarnessMemory (GuidanceEngine reads these forward into future generations)');
  } finally {
    sinterFs.close();
  }
  process.exit(0);
}
