// Load config and set env vars for LLMClient to pick up
async function initializeConfig() {
  const config = await getEffectiveConfig(undefined, process.cwd());

  // Set env vars so LLMClient picks them up
  // Note: provider is no longer used - we use baseUrl + model directly
  // Only set if not already set in environment (respect user env vars)
  if (config.baseUrl && !process.env.LIMINAL_LLM_BASE_URL) process.env.LIMINAL_LLM_BASE_URL = config.baseUrl;
  // Propagate model — auto-detect from /v1/models only works for local LM Studio;
  // remote providers (MiniMax, OpenRouter, etc.) need an explicit model name.
  if (config.model && !process.env.LIMINAL_LLM_MODEL) process.env.LIMINAL_LLM_MODEL = config.model;
  if (config.apiKey && !process.env.LIMINAL_LLM_API_KEY) process.env.LIMINAL_LLM_API_KEY = config.apiKey;

  return config;
}

// Initialize prompt history
const history = new PromptHistory();

// Handle --configure flag
if (flags.configure) {
  const providerKey = resolveCliProvider(flags.provider) || 'lmstudio';
  const providerDefaults = CLI_PROVIDER_DEFAULTS[providerKey];
  console.log('');
  console.log('🎨 Sinter Configuration');
  console.log('');
  console.log(`Setting up ${providerDefaults.label} config...`);
  console.log('');

  const config = {
    defaultProvider: providerKey,
    providers: {
      [providerKey]: {
        baseUrl: providerDefaults.baseUrl,
        model: flags.model || providerDefaults.model
      }
    }
  };

  saveConfig(config).then(() => {
    console.log('✅ Config saved to ~/.sinter/config.json');
    console.log('');
    console.log('You can now run:');
    console.log('  sinter --prompt "your idea"');
    if (providerDefaults.requiresKey && providerDefaults.apiKeyEnv) {
      console.log('');
      console.log(`Set ${providerDefaults.apiKeyEnv} before generating with ${providerDefaults.label}.`);
    }
    console.log('');
    process.exit(0);
  }).catch(err => {
    console.error('❌ Error saving config:', err.message);
    process.exit(1);
  });

  // Don't exit yet - wait for saveConfig
}

// Override config with CLI flags
if (flags.provider) {
  const providerKey = resolveCliProvider(flags.provider);
  if (providerKey) {
    const providerDefaults = CLI_PROVIDER_DEFAULTS[providerKey];
    process.env.LIMINAL_LLM_PROVIDER = providerKey;
    process.env.LIMINAL_LLM_BASE_URL = providerDefaults.baseUrl;
    if (!process.env.LIMINAL_LLM_MODEL) process.env.LIMINAL_LLM_MODEL = providerDefaults.model;
    console.log(`[CLI] Using ${providerDefaults.label} endpoint: ${providerDefaults.baseUrl}`);
  } else {
    console.warn(`[CLI] Unknown provider: ${flags.provider}. Use one of: ${CLI_PROVIDER_NAMES.join(', ')}, or set LIMINAL_LLM_BASE_URL.`);
  }
}
if (flags.model) {
  process.env.LIMINAL_LLM_MODEL = flags.model;
}

// Handle --recent flag
