// Keep improvement scans on a narrow startup path. The general CLI initializes
// provider config, guardrails, and the Meta-Harness; scan gates need to observe
// the repo without inheriting those runtime side effects.
if (cmd === 'improve') {
  const subCmd = cmdArgs[0] || 'scan';
  const {
    collectRepositoryOpportunityEvidence,
    formatOpportunityReport,
    scanGreenSystemOpportunities,
  } = await import('../dist/improvement/OpportunityScanner.js');
  const evidence = collectRepositoryOpportunityEvidence(process.cwd());
  if (flags.gatesPassed) {
    evidence.gates = [
      { name: 'build', status: 'pass', command: 'pnpm build', detail: 'caller asserted after running release gates' },
      { name: 'lint', status: 'pass', command: 'pnpm lint', detail: 'caller asserted after running release gates' },
      { name: 'fast tests', status: 'pass', command: 'pnpm test:ci:fast', detail: 'caller asserted after running release gates' },
      { name: 'slow tests', status: 'pass', command: 'pnpm test:ci:slow', detail: 'caller asserted after running release gates' },
    ];
  }
  const report = scanGreenSystemOpportunities(evidence);

  if (subCmd === 'scan') {
    const outputText = formatOpportunityReport(report);
    console.log('');
    console.log(outputText);
    console.log('');
    if (flags.output) {
      fs.writeFileSync(flags.output, `${JSON.stringify(report, null, 2)}\n`, 'utf-8');
      console.log(`Wrote improvement report: ${flags.output}`);
    }
    process.exit(0);
  }

  if (subCmd === 'run') {
    const proposalId = cmdArgs[1];
    if (!proposalId) {
      console.error('Usage: sinter improve run <proposal-id>');
      process.exit(1);
    }

    const proposal = report.proposals.find((item) => item.id === proposalId);
    if (!proposal) {
      console.error(`Unknown proposal: ${proposalId}`);
      console.error('Run `sinter improve scan` to see current proposals.');
      process.exit(1);
    }

    const inWorktree = isIsolatedWorktree();
    if (!inWorktree && process.env.LIMINAL_ALLOW_MAIN_WORKTREE_IMPROVE !== '1') {
      console.error('Refusing to mutate the main worktree. Create an isolated worktree, then rerun this command there.');
      console.error('Override only for deliberate local experiments: LIMINAL_ALLOW_MAIN_WORKTREE_IMPROVE=1');
      process.exit(2);
    }

    const { LLMModeSelfImprovementRuntime } = await import('../dist/runtime-core/SelfImprovementRuntime.js');
    const { LLMClient } = await import('../dist/llm/LLMClient.js');
    const runtime = new LLMModeSelfImprovementRuntime();
    const llm = new LLMClient({ role: 'harness' });
    const description = [
      `Run type: ${report.runType}`,
      `Proposal: ${proposal.title}`,
      `Category: ${proposal.category}`,
      `Evidence: ${proposal.evidence.join('; ')}`,
      `Measurable target: ${proposal.measurableTarget}`,
      `Expected verification: ${proposal.expectedVerification.join(' && ')}`,
      'Produce a reviewable patch and verification report. Do not auto-merge.',
    ].join('\n');
    const result = await runtime.run({ llm, description });

    console.log('');
    console.log('=== Self-healing run complete ===');
    console.log(`  Task: ${result.taskId}`);
    console.log(`  Model: ${result.modelName}`);
    console.log(`  Status: ${result.session.status}`);
    console.log(`  Steps: ${result.session.stepCount}`);
    console.log('');
    process.exit(result.session.status === 'success' ? 0 : 1);
  }

  console.error('Usage: sinter improve <scan|run>');
  process.exit(1);
}


