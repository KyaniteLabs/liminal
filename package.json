{
  "name": "sinter",
  "version": "2.1.0",
  "description": "Sinter — a creative-coding studio that generates across many visual/audio domains and fires them into one layered work (to sinter: fuse many particles into a single solid form, the way a kiln fuses clay)",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "author": "Simon Gonzalez de Cruz",
  "license": "BUSL-1.1",
  "packageManager": "pnpm@10.34.3",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/KyaniteLabs/liminal.git"
  },
  "homepage": "https://kyanitelabs.github.io/liminal/",
  "bugs": {
    "url": "https://github.com/KyaniteLabs/liminal/issues"
  },
  "files": [
    "dist",
    "bin",
    "scripts/packaging",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "scripts": {
    "domain:gauntlet": "node scripts/domains/gauntlet.mjs --domain",
    "domain:all": "node scripts/domains/gauntlet.mjs --all",
    "domain:ratchet": "node scripts/domains/gauntlet.mjs --all --ratchet",
    "domain:ratchet:ci": "node scripts/domains/ratchet-ci-proof.mjs",
    "postinstall": "node scripts/packaging/postinstall.mjs",
    "prepack": "npm run build",
    "build": "tsc --incremental false",
    "test": "vitest run",
    "test:integration": "vitest run test/integration --coverage=false",
    "verify:integration": "npm run build && vitest run test/integration --coverage=false",
    "test:e2e": "vitest run test/e2e --coverage=false",
    "test:cloud": "RUN_CLOUD_MODEL_TESTS=1 vitest run test/e2e --coverage=false",
    "gui": "pnpm build && node scripts/utils/start-studio.js",
    "gui:dev": "pnpm --dir gui dev",
    "desktop": "pnpm desktop:build && electron electron/main.cjs",
    "desktop:dev": "pnpm build && electron electron/main.cjs --dev",
    "desktop:build": "pnpm build && pnpm --dir gui build",
    "desktop:smoke": "node scripts/proof/electron-smoke.mjs",
    "desktop:package:mac": "pnpm desktop:build && node scripts/packaging/package-electron-mac.mjs",
    "studio": "npm run gui",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src/ --cache --cache-location .eslintcache",
    "check:examples": "node scripts/ci/smoke-composition-examples.mjs",
    "check:doc-links": "node scripts/ci/check-doc-links.mjs",
    "check:sinter-contracts": "node scripts/ci/check-sinter-shared-artifacts.mjs",
    "test:quality": "node scripts/testing/test-quality-check.mjs --baseline scripts/testing/test-quality-baseline.txt",
    "test:quality:strict": "node scripts/testing/test-quality-check.mjs --strict --baseline scripts/testing/test-quality-baseline.txt",
    "final-qa:test-quality": "pnpm test:quality:strict",
    "final-qa:surface": "node scripts/ci/final-qa-surface-gate.mjs",
    "gui:build": "pnpm --dir gui build",
    "sing:build": "pnpm --filter sing build",
    "sing:typecheck": "pnpm --filter sing typecheck",
    "sing:dev": "pnpm --filter sing dev",
    "sing:bench:phrases": "pnpm --filter sing bench:phrases",
    "typecheck": "tsc --noEmit",
    "docs": "typedoc --out docs src/",
    "dogfood:report": "npx tsx scripts/generate-dogfood-report.ts",
    "prepare": "node scripts/packaging/prepare-package.mjs",
    "git:hygiene": "bash scripts/utils/git-hygiene.sh",
    "git:hygiene:dry": "bash scripts/utils/git-hygiene.sh --dry-run",
    "proof:ml-value": "tsx scripts/proof/ml-value-proof.ts",
    "proof:git-ci-install": "node scripts/proof/git-ci-install.mjs",
    "proof:launch-risk": "tsx scripts/proof/launch-risk-proof.ts",
    "proof:studio-smoke": "tsx scripts/proof/studio-smoke.ts",
    "test:ci:fast": "LIMINAL_CI_FAST=1 vitest run --coverage=false --pool=forks --maxWorkers=1 --no-file-parallelism",
    "test:ci:slow": "LIMINAL_CI_SLOW=1 vitest run --pool=forks",
    "check:orphans": "bash scripts/check-orphans.sh",
    "check:script-targets": "node scripts/ci/check-package-script-targets.mjs",
    "dispatch:worker": "bash scripts/dispatch/cli-worker.sh",
    "proof:cognitive-loop": "tsx scripts/proof/cognitive-loop-proof.ts",
    "proof:model-assimilation": "tsx scripts/proof/model-assimilation-proof.ts",
    "proof:live-provider-smoke": "tsx scripts/proof/live-provider-smoke.ts",
    "proof:live-creative-domains": "tsx scripts/proof/live-creative-domain-execution.ts",
    "proof:live-model-assimilation": "tsx scripts/proof/model-assimilation-proof.ts --live",
    "proof:user-surfaces": "tsx scripts/proof/user-surfaces-e2e.ts",
    "proof:user-surface-observability": "tsx scripts/proof/user-surface-observability.ts",
    "proof:user-surface-controls": "tsx scripts/proof/user-surface-controls.ts",
    "proof:gui-bundle-budget": "tsx scripts/proof/gui-bundle-budget.ts",
    "qa:creative-domains": "node scripts/qa-creative-domains.mjs",
    "qa:creative-domains:static": "node scripts/qa-creative-domains.mjs --no-serve",
    "proof:visual-output-previews": "tsx scripts/proof/visual-output-preview-contract.ts",
    "proof:studio-launch-gauntlet": "node scripts/proof/studio-launch-gauntlet.mjs",
    "proof:route-performance": "tsx scripts/proof/route-performance-budget.ts",
    "quality:rescore": "node scripts/quality/rescore-tops.mjs",
    "quality:rescore:floors": "node scripts/quality/rescore-tops.mjs --floors",
    "reliability:probe": "node scripts/quality/reliability-probe.mjs",
    "quality:failures": "node scripts/quality/failure-class-report.mjs",
    "quality:render": "node scripts/quality/render.mjs",
    "quality:render-gallery": "node scripts/quality/render-gallery.mjs",
    "quality:matrix": "node scripts/quality/matrix.mjs"
  },
  "keywords": [
    "generative-art",
    "creative-coding",
    "p5js",
    "agent"
  ],
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@testing-library/react": "^16.3.2",
    "@types/archiver": "^7.0.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/cookie-parser": "^1.4.10",
    "@types/express": "^5.0.6",
    "@types/helmet": "^4.0.0",
    "@types/mdast": "^4.0.4",
    "@types/node": "^20.11.0",
    "@types/react": "^18.3.28",
    "@types/react-dom": "^18.3.7",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@vitest/coverage-v8": "^4.1.2",
    "concurrently": "^9.1.0",
    "electron": "^41.5.0",
    "eslint": "^8.57.1",
    "jsdom": "^29.0.1",
    "playwright": "^1.59.1",
    "vite": "8.0.16",
    "vitest": "^4.1.2"
  },
  "dependencies": {
    "@babel/parser": "^7.29.2",
    "@babel/traverse": "^7.29.0",
    "@babel/types": "^7.29.0",
    "@sinter/audio-core": "workspace:*",
    "@types/babel__traverse": "^7.28.0",
    "@xenova/transformers": "^2.17.2",
    "archiver": "^7.0.1",
    "better-sqlite3": "^12.8.0",
    "brace-expansion": "2.1.1",
    "clipboardy": "^5.3.1",
    "cookie-parser": "^1.4.7",
    "csrf-csrf": "^4.0.3",
    "dotenv": "^17.4.0",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.0",
    "helmet": "^8.1.0",
    "ink": "^5.2.1",
    "lodash": "^4.18.0",
    "neverthrow": "^8.2.0",
    "open": "^11.0.0",
    "p5": "^1.11.12",
    "path-to-regexp": "8.4.2",
    "picomatch": "4.0.4",
    "posthog-node": "^5.35.3",
    "puppeteer": "^24.40.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "remark": "^15.0.1",
    "remark-parse": "^11.0.0",
    "simple-git": "^3.36.0",
    "tsx": "^4.21.0",
    "typescript": "^5.3.3",
    "unified": "^11.0.5",
    "zod": "^4.3.6"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "overrides": {
    "basic-ftp": "5.3.1",
    "hono": "4.12.25",
    "ip-address": "10.2.0",
    "@protobufjs/utf8": "1.1.1",
    "axios": "1.17.0",
    "picomatch": "4.0.4",
    "protobufjs": "7.6.4",
    "qs": "6.15.2",
    "vite": "8.0.16",
    "ws": "8.21.0",
    "shell-quote": "^1.8.4"
  },
  "bin": {
    "sinter": "bin/sinter",
    "liminal": "bin/sinter",
    "lim": "bin/sinter"
  },
  "optionalDependencies": {
    "@hyperframes/producer": "^0.6.0",
    "@revideo/2d": "^0.10.4",
    "@revideo/core": "^0.10.4",
    "@revideo/ffmpeg": "^0.10.4",
    "@revideo/renderer": "^0.10.4",
    "@revideo/ui": "^0.10.4",
    "@revideo/vite-plugin": "^0.10.4",
    "meyda": "^5.6.3",
    "music-metadata": "^11.12.3",
    "pitchfinder": "^2.3.4",
    "sharp": "^0.35.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "sharp",
      "esbuild",
      "electron",
      "protobufjs",
      "puppeteer",
      "better-sqlite3"
    ],
    "overrides": {
      "loader-utils": "2.0.4",
      "flatted": "3.4.2",
      "picomatch": "4.0.4",
      "brace-expansion": "2.1.1",
      "lodash": "^4.18.0",
      "cookie": "0.7.2",
      "path-to-regexp": "8.4.2",
      "basic-ftp": "5.3.1",
      "hono": "4.12.25",
      "ip-address": "10.2.0",
      "@protobufjs/utf8": "1.1.1",
      "axios": "1.17.0",
      "protobufjs": "7.6.4",
      "qs": "6.15.2",
      "vite": "8.0.16",
      "ws": "8.21.0",
      "uuid": "^14.0.0",
      "shell-quote": "^1.8.4"
    }
  }
}
