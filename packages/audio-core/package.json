{
  "name": "@liminal/audio-core",
  "version": "2.1.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./*.js": {
      "types": "./dist/*.d.ts",
      "import": "./dist/*.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "meyda": "^5.6.3",
    "pitchfinder": "^2.3.4"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "typescript": "^5.9.3"
  }
}
