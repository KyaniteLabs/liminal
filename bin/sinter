else if (cmd === 'taste' && cmdArgs[0] === 'eval') {
  const { PreferenceDatasetBuilder, TasteModelTrainer, TasteModelEvaluator } = await import('../dist/learning/index.js');
  const { SinterFS } = await import('../dist/fs/index.js');
  const { EmergenceHooks } = await import('../dist/emergence/index.js');

  const sinterFs = SinterFS.open(process.cwd());
  try {
    const hooks = new EmergenceHooks(sinterFs);
    const archive = hooks.getArchive();
    const elites = archive.getAllElites();

    if (elites.length < 4) {
      console.error('Not enough data for evaluation (need ≥4 archived entries).');
      process.exit(1);
    }

    const builder = new PreferenceDatasetBuilder();
    const dataset = builder.build(elites);

    const trainer = new TasteModelTrainer();
    const model = trainer.train(dataset.pairs);

    const evaluator = new TasteModelEvaluator();
    const result = evaluator.evaluate(dataset.pairs, model);

    console.log('');
    console.log('=== Taste Model Evaluation ===');
    console.log(`  Agreement: ${(result.agreement * 100).toFixed(1)}%`);
    console.log(`  Kendall tau: ${result.kendallTau.toFixed(3)}`);
    console.log(`  Calibration: ${(result.calibration * 100).toFixed(1)}%`);
    console.log(`  Pairs evaluated: ${result.pairCount}`);
    console.log(`  Beats baseline: ${result.beatsBaseline ? 'YES' : 'NO'}`);
    console.log('');
  } finally {
    sinterFs.close();
  }
}
else if (cmd === 'dream' && cmdArgs[0] === 'run') {
  const { DreamPlanner, RecombinationEngine } = await import('../dist/dreaming/index.js');
  const { SinterFS } = await import('../dist/fs/index.js');
  const { EmergenceHooks } = await import('../dist/emergence/index.js');

  const strategy = cmdArgs[1] || 'auto';

  const sinterFs = SinterFS.open(process.cwd());
  try {
    const hooks = new EmergenceHooks(sinterFs);
    const archive = hooks.getArchive();
    const cells = archive.getAllCells();
    const axes = ['order-chaos', 'sparse-dense', 'symmetry-asymmetry', 'smooth-bursty', 'static-evolving', 'harmonic-dissonant'];

    const planner = new DreamPlanner();
    const plan = planner.plan(cells, axes);

    if (plan.tasks.length === 0) {
      console.error('No dream tasks to plan — archive may be empty.');
      process.exit(1);
    }

    const engine = new RecombinationEngine();

    console.log('');
    console.log(`=== Dream Run (strategy: ${strategy}) ===`);
    console.log(`  Planned ${plan.tasks.length} dream tasks`);

    for (const task of plan.tasks.slice(0, 5)) {
      console.log(`  [${task.strategy}] priority=${task.priority.toFixed(1)} — ${task.reason}`);
      if (task.sources.length >= 2) {
        const result = engine.recombine(task.sources[0], task.sources[1]);
        console.log(`    → novelty=${result.noveltyScore.toFixed(3)} strategy=${result.strategy}`);
      }
    }
    console.log('');
  } finally {
    sinterFs.close();
  }
  process.exit(0);
}
else if (cmd === 'garden' && cmdArgs[0] === 'status') {
  const { GardenPolicy } = await import('../dist/autonomy/GardenPolicy.js');
