else if (cmd === 'consolidate' || flags.consolidate) {
  // Memory consolidation — compress raw episodes into semantic patterns
  const { MemoryConsolidator, ThompsonSampler, DomainPrototype, IntuitionCache } = await import('../dist/intuition/index.js');
  const { HarnessMemory } = await import('../dist/harness/HarnessMemory.js');

  console.log('');
  console.log('🧠 Sinter Memory Consolidation');
  console.log('');

  const memory = new HarnessMemory();
  await memory.initialize(); // load persisted episodes from disk before reading them
  const modelSampler = new ThompsonSampler({ minPulls: 1, successThreshold: 0.7 });
  const strategySampler = new ThompsonSampler({ minPulls: 1, successThreshold: 0.7 });
  const prototype = new DomainPrototype();
  const consolidator = new MemoryConsolidator(
    { modelSampler, strategySampler, prototype },
    { successThreshold: 0.7, minEpisodesForPattern: 2, maxPatterns: 200 },
  );

  // Load prior consolidated patterns so each run ACCUMULATES instead of starting
  // from scratch and discarding everything at process.exit — the patterns the
  // self-improve loop/daemon can read on the next cycle.
  const patternStorePath = path.join(process.env.HOME || '/tmp', '.sinter', 'intuition', 'consolidated-patterns.json');
  try {
    if (fs.existsSync(patternStorePath)) {
      consolidator.deserialize(JSON.parse(fs.readFileSync(patternStorePath, 'utf-8')));
      console.log(`  Loaded prior patterns: ${consolidator.patternCount} from ${patternStorePath}`);
    }
  } catch (err) {
    console.log(`  Prior patterns: load skipped (${err?.message ?? err})`);
  }

  // Convert HarnessMemory episodes to ConsolidationEpisodes
  const rawEpisodes = memory.getRecentEpisodes(500);
  const episodes = rawEpisodes
    .filter(e => e.type === 'generation' && e.score !== undefined)
    .map(e => ({
      domain: e.domain ?? 'p5',
      output: e.code ?? '',
      qualityScore: e.score,
      model: e.tags?.find(t => t.startsWith('model:'))?.replace('model:', ''),
      strategy: e.tags?.find(t => t.startsWith('strategy:'))?.replace('strategy:', ''),
      timestamp: e.timestamp,
    }));

  console.log(`  Raw episodes: ${episodes.length}`);

  const result = consolidator.consolidate(episodes);

  console.log(`  Patterns created: ${result.patternsCreated}`);
  console.log(`  Patterns pruned: ${result.patternsPruned}`);
  console.log(`  Prototype updates: ${result.prototypeUpdates}`);
  console.log(`  Duration: ${result.durationMs}ms`);
  console.log('');

  if (Object.keys(result.byDomain).length > 0) {
    console.log('  Domain breakdown:');
    for (const [domain, stats] of Object.entries(result.byDomain)) {
      console.log(`    ${domain}: ${stats.episodes} episodes, ${stats.patterns} patterns, avg quality ${stats.avgQuality.toFixed(3)}`);
    }
  }

  // Persist the consolidated patterns so they are NOT discarded at exit — the
  // loop/daemon (and the next consolidate run) read them back from this store.
  try {
    fs.mkdirSync(path.dirname(patternStorePath), { recursive: true });
    fs.writeFileSync(patternStorePath, JSON.stringify(consolidator.serialize(), null, 2), 'utf-8');
    console.log(`  Persisted ${consolidator.patternCount} patterns → ${patternStorePath}`);
  } catch (err) {
    console.log(`  ⚠ Persist FAILED (${err?.message ?? err}) — patterns NOT saved`);
  }

  console.log('');
  console.log('✅ Consolidation complete');
  console.log('');
  process.exit(0);
} else if (cmd === 'bridge') {
