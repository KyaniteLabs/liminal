#!/usr/bin/env node
import dotenv from "dotenv";
dotenv.config();

// Graceful top-level error handling
process.on('uncaughtException', (err) => {
  console.error(`Error: ${err.message || err}`);
  process.exit(1);
});

process.on('unhandledRejection', (reason) => {
  console.error(`Error: ${reason instanceof Error ? reason.message : reason}`);
  process.exit(1);
});

// Env back-compat: mirror SINTER_*/LIMINAL_* so both prefixes work whichever the
// user set (the canonical prefix is SINTER_; LIMINAL_ stays supported).
(function mirrorBrandEnv() {
  for (const key of Object.keys(process.env)) {
    const base = key.startsWith('SINTER_') ? key.slice(7)
      : key.startsWith('LIMINAL_') ? key.slice(8) : undefined;
    if (!base) continue;
    const value = process.env[key];
    if (value === undefined) continue;
    if (process.env[`SINTER_${base}`] === undefined) process.env[`SINTER_${base}`] = value;
    if (process.env[`LIMINAL_${base}`] === undefined) process.env[`LIMINAL_${base}`] = value;
  }
})();

import fs from 'fs';
import path from 'path';
import { fileURLToPath } from 'url';

const binDir = path.dirname(fileURLToPath(import.meta.url));
const repoRoot = path.join(binDir, '..');
const packageJson = JSON.parse(fs.readFileSync(path.join(repoRoot, 'package.json'), 'utf-8'));
const args = process.argv.slice(2);

// One-time config-home migration: if the new ~/.sinter home doesn't exist yet
// but a legacy ~/.sinter (or ~/.atelier) does, move it wholesale so existing
// keys/config/memory/gallery carry over. Runs before any config read.
(function migrateConfigHome() {
  const home = process.env.HOME || process.env.USERPROFILE;
  if (!home) return;
  const newDir = path.join(home, '.sinter');
  if (fs.existsSync(newDir)) return;
  for (const legacy of ['.liminal', '.atelier']) {
    const oldDir = path.join(home, legacy);
    if (!fs.existsSync(oldDir)) continue;
    try { fs.renameSync(oldDir, newDir); }
    catch {
      try {
        fs.mkdirSync(newDir, { recursive: true });
        fs.copyFileSync(path.join(oldDir, 'config.json'), path.join(newDir, 'config.json'));
      } catch { /* nothing to carry over */ }
    }
    break;
  }
})();

