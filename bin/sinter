// Handle --help flag (global)
if (flags.help) {
  printHelp();
  process.exit(0);
}

// Handle --version flag
if (flags.version) {
  console.log(`Sinter v${packageJson.version}`);
  process.exit(0);
}

if (cmd === 'provider') {
  const subCmd = cmdArgs[0] || 'help';
  if (subCmd === 'help' || subCmd === '--help' || subCmd === '-h') {
    printProviderHelp();
    process.exit(0);
  }
  if (subCmd === 'list') {
    printProviderList();
    process.exit(0);
  }
  if (subCmd === 'status') {
    printProviderStatus();
    process.exit(0);
  }
  if (subCmd === 'set-key') {
    // cmdArgs[0] is 'set-key'; --use/--model/--base-url are parsed into flags.
    const providerKey = resolveCliProvider(cmdArgs[1]);
    const apiKey = cmdArgs[2];
    const model = flags.model;
    const baseUrl = flags.baseUrl;
    const activate = !!flags.use;
    // Local servers (ollama/lmstudio) need no key; cloud providers do.
    const keyRequired = providerKey ? CLI_PROVIDER_DEFAULTS[providerKey].requiresKey : true;
    if (!providerKey || (keyRequired && !apiKey)) {
      console.error('Usage: sinter provider set-key <provider> [<API_KEY>] [--base-url <url>] [--model <id>] [--use]');
      console.error(`Providers: ${CLI_PROVIDER_NAMES.join(', ')}`);
      console.error('  Cloud:  sinter provider set-key minimax sk-... --use');
      console.error('  Local:  sinter provider set-key ollama --base-url http://192.168.1.50:11434/v1 --model qwen2.5-coder --use');
      process.exit(1);
    }
    try {
      const r = setProviderKey(providerKey, apiKey, { model, baseUrl, activate });
      console.log('');
      console.log(`✅ Saved ${CLI_PROVIDER_DEFAULTS[providerKey].label} provider to ${r.cfgPath}`);
      console.log(`   endpoint: ${r.baseUrl}`);
      console.log(`   model:    ${r.model}`);
      console.log(`   active:   ${r.activated ? 'yes (default — all roles inherit it)' : 'no (use --use to activate)'}`);
      console.log('');
      console.log(r.activated
        ? '   Try: sinter --prompt "a glsl aurora shader" --max-iterations 1 -o output/test'
        : `   Activate with: sinter provider set-key ${providerKey} ${keyRequired ? '<KEY> ' : ''}--use`);
      console.log('');
      process.exit(0);
    } catch (e) {
      console.error(`❌ ${e.message}`);
      process.exit(1);
    }
  }

  console.error(`Unknown provider subcommand: ${subCmd}`);
  console.error('Usage: sinter provider <help|list|status|set-key>');
  process.exit(1);
}

if (cmd === 'self-improve') {
  try {
    const subCmd = cmdArgs[0] || 'gauntlet';
    if (subCmd === 'gauntlet') {
      const { runSelfImprovementGauntlet } = await import('../dist/runtime-core/SelfImprovementReflexes.js');
      const report = runSelfImprovementGauntlet();
      console.log('');
      console.log('=== Self-improvement gauntlet ===');
      console.log(`Level: ${report.level}`);
      console.log(`Prompts: ${report.passed}/${report.total} passed`);
      console.log(`Organs: ${report.organsTouched.join(', ')}`);
      console.log('');
      for (const result of report.results) {
        console.log(`${result.status === 'pass' ? 'PASS' : 'FAIL'} ${result.id}`);
        console.log(`  domain=${result.domain} focus=${result.fileHint}`);
        console.log(`  reflex=${result.recommendedReflex.nextAction} organs=${result.organs.join(', ')}`);
      }
      if (flags.output) {
        fs.writeFileSync(flags.output, `${JSON.stringify(report, null, 2)}\n`, 'utf-8');
        console.log('');
        console.log(`Wrote gauntlet report: ${flags.output}`);
      }
      console.log('');
      process.exit(report.failed === 0 ? 0 : 1);
    }
    console.error('Usage: sinter self-improve gauntlet [--output report.json]');
    process.exit(1);
  } catch (err) {
    console.error(`Error: ${err.message}`);
    process.exit(1);
  }
}

if (cmd === 'domains') {
  const subCmd = cmdArgs[0] || 'gauntlet';
  if (subCmd === 'gauntlet') {
    const { runCreativeDomainGauntlet } = await import('../dist/runtime-core/CreativeDomainGauntlet.js');
    const report = runCreativeDomainGauntlet(repoRoot);
    console.log('');
    console.log('=== Creative domain gauntlet ===');
    console.log(`Domains: ${report.passed}/${report.total} passed`);
    for (const domain of report.domains) {
      console.log(`${domain.status === 'pass' ? 'PASS' : 'FAIL'} ${domain.label}`);
      console.log(`  prompt=${domain.prompt}`);
      console.log(`  verification=${domain.verification}`);
