{
  "name": "liminal",
  "version": "1.0.0",
  "loop": {
    "maxIterations": 20,
    "timeoutMinutes": 30,
    "completionPromise": "COMPLETE"
  },
  "llm": {
    "provider": "lmstudio",
    "baseUrl": "http://localhost:1234/v1",
    "model": "local-model",
    "temperature": 0.7,
    "maxTokens": 4096,
    "localFallback": true
  },
  "creative": {
    "defaultFramework": "p5.js",
    "evaluationCriteria": ["aesthetic", "technical", "novelty"],
    "minQualityScore": 0.7
  },
  "gallery": {
    "autoSave": true,
    "maxHistoryPerProject": 50
  },
  "renderer": {
    "port": 3456,
    "screenshotOnIteration": true
  },
  "live": {
    "oscHost": "127.0.0.1",
    "oscPort": 57120,
    "syncMode": "internal"
  }
}
