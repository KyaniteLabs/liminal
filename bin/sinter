    model: 'kimi-k2.5',
    requiresKey: true,
    apiKeyEnv: 'MOONSHOT_API_KEY',
  },
};
const CLI_PROVIDER_NAMES = Object.keys(CLI_PROVIDER_DEFAULTS);

function resolveCliProvider(value) {
  if (!value) return undefined;
  const normalized = value.toLowerCase();
  return CLI_PROVIDER_DEFAULTS[normalized] ? normalized : undefined;
}

function sinterConfigPath() {
  return path.join(process.env.HOME || process.env.USERPROFILE || '.', '.sinter', 'config.json');
}

// Write an API key (and provider block) into ~/.sinter/config.json, merging with
// whatever is already there. With `activate`, also point the generator+evaluator
// roles + defaultProvider at this provider so the next run uses it immediately.
function setProviderKey(providerKey, apiKey, { model, baseUrl, activate } = {}) {
  const defaults = CLI_PROVIDER_DEFAULTS[providerKey];
  if (!defaults) throw new Error(`Unknown provider: ${providerKey} (one of: ${CLI_PROVIDER_NAMES.join(', ')})`);
  const cfgPath = sinterConfigPath();
  let config = {};
  if (fs.existsSync(cfgPath)) {
    try { config = JSON.parse(fs.readFileSync(cfgPath, 'utf-8')); }
    catch (e) { throw new Error(`Existing config is not valid JSON (${cfgPath}): ${e.message}`); }
  }
  // baseUrl override lets a provider point at a self-hosted endpoint (e.g. a
  // remote Ollama/vLLM/LM Studio on a home server) instead of its default URL.
  const block = {
    baseUrl: baseUrl || defaults.baseUrl,
    model: model || defaults.model,
  };
  if (apiKey) block.apiKey = apiKey; // keyless local servers (ollama/lmstudio) need none
  config.providers = { ...(config.providers || {}), [providerKey]: block };
  if (activate) {
    config.defaultProvider = providerKey;
    // Switching the active provider resets roles to a single generator entry;
    // evaluator/harness/studio inherit it. Replacing (not merging) avoids leaving
    // stale per-role overrides pointing at the previous provider. Power users who
    // want a different model per role set roles.* in config.json directly.
    const roleBlock = { provider: providerKey, ...block };
    config.roles = { generator: { ...roleBlock } };
  }
  fs.mkdirSync(path.dirname(cfgPath), { recursive: true });
  // Atomic write (tmp + rename) so a crash never leaves a corrupt config; mode 0o600
  // because it holds API keys. Mirrors src/utils/atomicWrite.ts (kept inline here to keep
  // the early --configure bootstrap path free of a dist dependency).
  const tmpCfg = `${cfgPath}.tmp-${process.pid}`;
  fs.writeFileSync(tmpCfg, JSON.stringify(config, null, 2) + '\n', { mode: 0o600 });
  fs.renameSync(tmpCfg, cfgPath);
  return { cfgPath, model: block.model, baseUrl: block.baseUrl, activated: !!activate };
}

function printProviderHelp() {
  console.log('');
  console.log('🔌 Sinter Provider Setup');
  console.log('');
  console.log('USAGE:');
  console.log('  sinter provider help');
  console.log('  sinter provider list');
  console.log('  sinter provider status');
  console.log('  sinter provider set-key <name> [<API_KEY>] [--base-url <url>] [--model <id>] [--use]');
  console.log('  sinter --configure --provider <name>');
  console.log('');
  console.log('PROVIDERS:');
  for (const [name, provider] of Object.entries(CLI_PROVIDER_DEFAULTS)) {
    const keyHint = provider.requiresKey && provider.apiKeyEnv
      ? `requires ${provider.apiKeyEnv}`
      : 'no API key required';
    console.log(`  ${name.padEnd(10)} ${provider.label.padEnd(13)} model=${provider.model} (${keyHint})`);
  }
  console.log('');
  console.log('EXAMPLES:');
  console.log('  sinter --configure --provider lmstudio');
  console.log('  sinter provider set-key minimax sk-... --use   # MiniMax-M3, international endpoint, made active');
  console.log('  GLM_API_KEY=... sinter --provider glm "make a p5 sketch"');
  console.log('  sinter provider status');
  console.log('');
}

function printProviderList() {
  console.log('');
  console.log('Available Sinter providers:');
  for (const name of CLI_PROVIDER_NAMES) {
    const provider = CLI_PROVIDER_DEFAULTS[name];
    console.log(`  ${name.padEnd(10)} ${provider.label} (${provider.baseUrl})`);
  }
  console.log('');
}

function readSinterConfig() {
  try {
    const p = sinterConfigPath();
    if (fs.existsSync(p)) return JSON.parse(fs.readFileSync(p, 'utf-8'));
  } catch { /* ignore unreadable/invalid config */ }
  return {};
}

function savedKeyFor(name, config) {
  const fromProvider = config.providers?.[name]?.apiKey;
  const fromRole = ['generator', 'evaluator', 'harness']
    .map((r) => config.roles?.[r])
    .find((role) => role?.provider === name && role?.apiKey)?.apiKey;
  return Boolean(fromProvider || fromRole);
}

function printProviderStatus() {
  const config = readSinterConfig();
  const active = config.defaultProvider;
  console.log('');
  console.log('Sinter provider readiness:');
  for (const [name, provider] of Object.entries(CLI_PROVIDER_DEFAULTS)) {
    // Ready if no key needed, or a key is present in env OR the saved config.
    const hasKey = Boolean(process.env[provider.apiKeyEnv]) || savedKeyFor(name, config);
    const configured = !provider.requiresKey || hasKey;
    const status = configured ? 'ready' : `missing key (set with: sinter provider set-key ${name} <KEY>)`;
    const activeMark = name === active ? ' (active)' : '';
    console.log(`  ${name.padEnd(10)} ${status}${activeMark}`);
  }
  console.log('');
  console.log('Set a key with `sinter provider set-key <name> <KEY> --use`.');
  console.log('');
}

// Parse flags
const flags = {};
let cmd = null;
let cmdArgs = [];
let prompt = null;
let maxIterations = 3;
let output = null;

for (let i = 0; i < args.length; i++) {
  const arg = args[i];
  if (arg === '--help' || arg === '-h') {
    flags.help = true;
  } else if (arg === '--version') {
    flags.version = true;
  } else if (arg === '--prompt' || arg === '-p') {
    flags.prompt = args[++i];
  } else if (arg === '--session') {
    flags.session = args[++i];
  } else if (arg === '--max-iterations' || arg === '-m') {
    flags.maxIterations = parseInt(args[++i]);
  } else if (arg === '--output' || arg === '-o') {
    flags.output = args[++i];
  } else if (arg === '--gallery') {
    flags.gallery = args[++i];
  } else if (arg === '--input' || arg === '-f') {
    flags.input = args[++i];
  } else if (arg === '--provider') {
    flags.provider = args[++i];
  } else if (arg === '--model') {
    flags.model = args[++i];
  } else if (arg === '--base-url') {
    flags.baseUrl = args[++i];
  } else if (arg === '--configure') {
    flags.configure = true;
  } else if (arg === '--use' || arg === '--activate') {
    flags.use = true;
  } else if (arg === '--recent') {
    const nextArg = args[i + 1];
    if (nextArg && !nextArg.startsWith('-') && !isNaN(parseInt(nextArg))) {
      flags.recent = parseInt(args[++i]);
    } else {
      flags.recent = 10;
    }
  } else if (arg === '--favorite') {
    flags.favorite = args[++i];
  } else if (arg === '--favorites') {
    flags.favorites = true;
  } else if (arg === '--mode') {
    flags.mode = args[++i];
  } else if (arg === '--use-swarm') {
    flags.useSwarm = true;
  } else if (arg === '--swarm-mode') {
    flags.swarmMode = args[++i];
  } else if (arg === '--swarm-rounds') {
    flags.swarmRounds = parseInt(args[++i]);
  } else if (arg === '--fast-model') {
    flags.fastModel = args[++i];
  } else if (arg === '--candidate') {
    flags.candidate = args[++i];
  } else if (arg === '--to') {
    flags.to = args[++i];
  } else if (arg === '--powerful-model') {
    flags.powerfulModel = args[++i];
  } else if (arg === '--routing-mode') {
    flags.routingMode = args[++i];
  } else if (arg === '--confidence-threshold') {
    flags.confidenceThreshold = parseFloat(args[++i]);
  } else if (arg === '--spec') {
    flags.spec = args[++i];
  } else if (arg === '--voice') {
    flags.voice = true;
  } else if (arg === '--voice-file') {
    flags.voiceFile = args[++i];
  } else if (arg === '--aesthetic') {
    flags.aesthetic = args[++i];
  } else if (arg === '--aesthetic-config') {
    flags.aestheticConfig = args[++i];
  } else if (arg === '--learn') {
    flags.learn = true;
  } else if (arg === '--intuition') {
    flags.intuition = true;
  } else if (arg === '--consolidate') {
    flags.consolidate = true;
  } else if (arg === '--error') {
    flags.error = args[++i];
  } else if (arg === '--test-failures') {
    flags.testFailures = true;
  } else if (arg === '--test-file') {
    flags.testFile = args[++i];
  } else if (arg === '--dry-run') {
    flags.dryRun = true;
  } else if (arg === '--force') {
    flags.force = true;
  } else if (arg === '--gates-passed') {
    flags.gatesPassed = true;
  } else if (arg === '--confirm') {
    flags.confirm = args[++i];
  } else if (arg.startsWith('--confirm=')) {
    flags.confirm = arg.split('=')[1];
  } else if (arg === '--verbose' || arg === '-v') {
    flags.verbose = true;
  } else if (arg === '--script-only') {
    flags.scriptOnly = true;
  } else if (arg === '--spec-only') {
    flags.specOnly = true;
  } else if (!arg.startsWith('-')) {
    if (cmd === null) { cmd = arg; } else { cmdArgs.push(arg); }
  }
}


function isIsolatedWorktree(cwd = process.cwd()) {
  return cwd.includes(`${path.sep}.worktrees${path.sep}`)
    || cwd.includes(`${path.sep}.claude${path.sep}worktrees${path.sep}`);
}

function loadAestheticConfig(configPath) {
  if (!configPath) return undefined;
  const resolvedPath = path.resolve(configPath);
  try {
    return JSON.parse(fs.readFileSync(resolvedPath, 'utf-8'));
  } catch (err) {
    const message = err instanceof Error ? err.message : String(err);
    console.error(`Error: failed to load --aesthetic-config from ${resolvedPath}: ${message}`);
    process.exit(1);
  }
}


function summarizeSession(session) {
  return {
    status: session.status,
    exitReason: session.exitReason,
    startTime: session.startTime,
    endTime: session.endTime,
    stepCount: session.stepCount,
    mutatedFiles: Array.from(session.mutatedFiles || []),
    successfulMutatedFiles: Array.from(session.successfulMutatedFiles || []),
    exploredPaths: Array.from(session.exploredPaths || []),
    messages: (session.messages || []).map((message) => ({
      role: message.role,
      content: typeof message.content === 'string' ? message.content.slice(0, 4000) : message.content,
      toolCall: message.toolCall,
      toolResult: message.toolResult,
    })),
  };
}

