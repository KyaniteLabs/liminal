else if (cmd === 'emergence') {
  const subCmd = cmdArgs[0];

  if (subCmd === 'score') {
    const { EmergenceCritic, BehaviorDescriptorExtractor } = await import('../dist/emergence/index.js');
    const { EmergenceScorecard } = await import('../dist/evaluation/EmergenceScorecard.js');

    const output = cmdArgs[1] ? String(cmdArgs[1]) : null;
    if (!output) {
      console.error('Usage: sinter emergence score <text-or-file-path>');
      process.exit(1);
    }

    // Check if it's a file path
    let text = output;
    try {
      const { readFileSync } = await import('fs');
      text = readFileSync(output, 'utf-8');
    } catch { /* not a file path, use as raw text */ }

    const extractor = new BehaviorDescriptorExtractor();
    const critic = new EmergenceCritic();
    const scorecard = new EmergenceScorecard();

    const descriptor = extractor.extract(text);
    const result = critic.evaluateQuick({
      descriptor,
      qualityScore: 0.5,
      archive: [],
      output: text,
    });

    const card = scorecard.score(result.signals, result.composite);
    console.log('');
    console.log(scorecard.format(card));
  } else if (subCmd === 'probe') {
    const { PerturbationProbe, BehaviorDescriptorExtractor } = await import('../dist/emergence/index.js');

    const output = cmdArgs[1] ? String(cmdArgs[1]) : null;
    if (!output) {
      console.error('Usage: sinter emergence probe <text-or-file-path> [--magnitude 0.1]');
      process.exit(1);
    }

    let text = output;
    try {
      const { readFileSync } = await import('fs');
      text = readFileSync(output, 'utf-8');
    } catch { /* not a file path, use as raw text */ }

    const extractor = new BehaviorDescriptorExtractor();
    const probe = new PerturbationProbe();

    const descriptor = extractor.extract(text);
    const result = probe.probe(text, descriptor, (t) => extractor.extract(t));

    console.log('');
    console.log(`Perturbation Resilience: ${result.resilience.toFixed(3)} [${result.classification}]`);
    for (const p of result.perturbations) {
      console.log(`  ${p.type}: ${p.score.toFixed(3)}`);
    }
    console.log('');
  } else {
    console.error('Usage: sinter emergence <score|probe> <text-or-file-path>');
    process.exit(1);
  }
  process.exit(0);
}
