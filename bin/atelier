#!/usr/bin/env node
import { P5GeneratorLLM as P5Generator, PreviewServer } from '../dist/index.js';
import fs from 'fs';
import path from 'path';

const cmd = process.argv[2];
const arg = process.argv[3];

if (cmd === 'generate' || cmd === 'gen' || cmd === 'g') {
  const prompt = arg || process.argv.slice(3).join(' ');
  if (!prompt) {
    console.log('Usage: atelier generate "your prompt"');
    process.exit(1);
  }
  console.log('Generating:', prompt);
  const code = P5Generator.generate(prompt, {});
  const outDir = path.join(process.env.HOME, '.atelier', 'output');
  fs.mkdirSync(outDir, { recursive: true });
  const file = path.join(outDir, 'sketch-' + Date.now() + '.js');
  fs.writeFileSync(file, code);
  console.log('✅ Saved:', file);
  console.log('\nPreview:');
  console.log(code.substring(0, 300) + '...');
} 
else if (cmd === 'serve' || cmd === 's') {
  const port = arg || 3456;
  const server = new PreviewServer();
  server.start(port).then(() => {
    console.log('✅ Server running on http://localhost:' + port);
  });
}
else if (cmd === 'list' || cmd === 'ls') {
  const outDir = path.join(process.env.HOME, '.atelier', 'output');
  console.log('📁 Sketches:');
  if (fs.existsSync(outDir)) {
    fs.readdirSync(outDir).filter(f => f.endsWith('.js')).forEach(f => console.log('  ' + f));
  } else {
    console.log('  (none yet)');
  }
}
else {
  console.log('');
  console.log('🎨 Atelier - Creative Coding Agent');
  console.log('');
  console.log('Commands:');
  console.log('  atelier generate "prompt"   Create p5.js art from prompt');
  console.log('  atelier serve [port]        Start preview server (default: 3456)');
  console.log('  atelier list                Show saved sketches');
  console.log('');
  console.log('Examples:');
  console.log('  atelier generate "blue particles"');
  console.log('  atelier serve');
  console.log('  atelier list');
  console.log('');
}
